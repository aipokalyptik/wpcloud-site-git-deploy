#!/usr/bin/env bash
set -euo pipefail

readonly VERSION="1.1.2"
# Default number of promoted docroot releases retained for rollback.
readonly DEFAULT_KEEP_RELEASES="3"
# Default tool-owned WordPress maintenance marker created during promotion.
readonly DEFAULT_MAINTENANCE_FILE=".maintenance"
# Web-visible deployment namespace under the docroot.
readonly DOCROOT_NAMESPACE=".wpcloud-site-git-deploy"
readonly DOCROOT_NAMESPACE_SUFFIX="${DOCROOT_NAMESPACE#.}"
readonly DOCROOT_NAMESPACE_REGEX="\\.wpcloud-site-git-deploy"
# WordPress-managed persistent paths should never be claimed by a Git deploy.
readonly -a DEFAULT_SHARED_PATHS=(wp-content/uploads wp-content/cache wp-content/upgrade wp-content/blogs.dir .maintenance)
# Metadata keys written for each successful release and accepted by the
# non-executing metadata reader.
readonly -a RELEASE_METADATA_KEYS=(release_id ref_mode ref_value commit deploy_root deployed_at)

# Location of this checked-out or installed CLI. Source installs use REPO_ROOT
# to find the bundled helper; managed installs primarily use STATE_DIR instead.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# Tool-owned runtime state. Override with WPCLOUD_SITE_GIT_DEPLOY_HOME in tests
# or nonstandard installs; production defaults to the site SSH user's HOME.
STATE_DIR="${WPCLOUD_SITE_GIT_DEPLOY_HOME:-$HOME/.wpcloud-site-git-deploy}"
# Per-deployment config files, repo caches, transient worktrees, installed
# helper binaries, and deploy keys are intentionally kept outside the docroot.
DEPLOYMENTS_DIR="$STATE_DIR/deployments"
REPOS_DIR="$STATE_DIR/repos"
TMP_DIR="$STATE_DIR/tmp"
BIN_DIR="$STATE_DIR/bin"
KEYS_DIR="$STATE_DIR/keys"
# Fallback helper path when running directly from a source checkout.
HELPER_SOURCE="$REPO_ROOT/helpers/bin/linux-amd64/exchange-rename"

# Common CLI helpers

usage() {
  cat <<-'USAGE'
	wpcloud-site-git-deploy deploys a Git repository into a WP Cloud or Pressable docroot from the site SSH user.

	Usage:
	  wpcloud-site-git-deploy init <name> --repo URL --docroot /srv/htdocs --deployment-id ID --default-ref main [--keep-releases N] [--deploy-root PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy config <name> [--deploy-root PATH | --clear-deploy-root | --post-deploy PATH | --clear-post-deploy | --maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --branch BRANCH [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --tag TAG [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --commit SHA [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy update <name> [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy rollback <name> [--to RELEASE_ID]
	  wpcloud-site-git-deploy releases <name>
	  wpcloud-site-git-deploy branches <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy tags <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy commits <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy status <name>
	  wpcloud-site-git-deploy auth <name> [--force-new-key] [--verify] [--use-key PATH | --import-key PATH | --remove [--purge-key]]
	  wpcloud-site-git-deploy doctor <name> [--offline]
	  wpcloud-site-git-deploy --help
	  wpcloud-site-git-deploy --version
	USAGE
}

die() {
  echo "wpcloud-site-git-deploy: $*" >&2
  exit 64
}

require_name() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] || die "deployment name must contain only letters, numbers, dot, underscore, or dash"
}

require_id() {
  [[ "${1:-}" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "deployment-id must be a normalized id"
}

shell_quote() {
  printf '%q' "$1"
}

config_path() {
  local name="$1"
  printf '%s/%s.env\n' "$DEPLOYMENTS_DIR" "$name"
}

docroot_deployment_base() {
  local root="$1"
  local id="$2"

  printf '%s/%s/deployments/%s\n' "$root" "$DOCROOT_NAMESPACE" "$id"
}

write_config_value() {
  local key="$1"
  local value="$2"
  printf '%s=%s\n' "$key" "$(shell_quote "$value")"
}

# Deployment config and state

load_config() {
  local name="$1"
  local path

  require_name "$name"
  path="$(config_path "$name")"
  [[ -f "$path" ]] || die "deployment is not initialized: $name"

  # Config files are owned runtime state under $HOME. They are written only by
  # this CLI using shell-quoted assignments, then sourced so values with spaces
  # survive round-trips without adding a parser dependency.
  # shellcheck disable=SC1090
  source "$path"

  : "${repo_url:?}"
  : "${docroot:?}"
  : "${deployment_id:?}"
  : "${default_ref:?}"
  keep_releases="${keep_releases:-$DEFAULT_KEEP_RELEASES}"
  ssh_key_path="${ssh_key_path:-}"
  deploy_root="${deploy_root:-}"
  post_deploy="${post_deploy:-}"
  maintenance_file="${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}"
}

ensure_state_dirs() {
  mkdir -p "$DEPLOYMENTS_DIR" "$REPOS_DIR" "$TMP_DIR" "$BIN_DIR" "$KEYS_DIR"
}

write_config() {
  local name="$1"
  local path

  path="$(config_path "$name")"
  {
    write_config_value repo_url "$repo_url"
    write_config_value docroot "$docroot"
    write_config_value deployment_id "$deployment_id"
    write_config_value default_ref "$default_ref"
    write_config_value keep_releases "$keep_releases"
    if [[ -n "${deploy_root:-}" ]]; then
      write_config_value deploy_root "$deploy_root"
    fi
    if [[ -n "${post_deploy:-}" ]]; then
      write_config_value post_deploy "$post_deploy"
    fi
    if [[ "${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}" != "$DEFAULT_MAINTENANCE_FILE" ]]; then
      write_config_value maintenance_file "$maintenance_file"
    fi
    if [[ -n "${ssh_key_path:-}" ]]; then
      write_config_value ssh_key_path "$ssh_key_path"
    fi
  } >"$path"
  chmod 600 "$path"
}

require_post_deploy_path() {
  local value="$1"

  [[ -n "$value" ]] || die "post-deploy path must not be empty"
  [[ "$value" != *$'\n'* ]] || die "post-deploy path must not contain newlines"
}

require_maintenance_file() {
  local value="$1"
  local die_fn="${2:-die}"
  local component
  local rest

  if [[ "$value" == "none" ]]; then
    return 0
  fi

  [[ -n "$value" ]] || "$die_fn" "maintenance-file must be a safe relative path or none"
  [[ "$value" != /* ]] || "$die_fn" "maintenance-file must be a safe relative path or none"
  [[ "$value" != *$'\n'* ]] || "$die_fn" "maintenance-file must be a safe relative path or none"
  [[ "$value" != */ ]] || "$die_fn" "maintenance-file must be a safe relative path or none"
  [[ "$value" != *//* ]] || "$die_fn" "maintenance-file must be a safe relative path or none"

  rest="$value"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" == */* ]]; then
      component="${rest%%/*}"
      rest="${rest#*/}"
    else
      component="$rest"
      rest=""
    fi
    [[ "$component" != "." && "$component" != ".." && -n "$component" ]] || "$die_fn" "maintenance-file must be a safe relative path or none"
  done
}

require_deploy_root() {
  local value="$1"
  local component
  local rest

  # Empty would be ambiguous with the default repository root. Callers clear
  # deploy_root explicitly instead of storing an empty configured path.
  [[ -n "$value" ]] || die "deploy-root must be a safe relative path"
  # Absolute paths would let deploy-root escape the checked-out repository.
  [[ "$value" != /* ]] || die "deploy-root must be a safe relative path"
  # Newlines would corrupt shell config and metadata line formats.
  [[ "$value" != *$'\n'* ]] || die "deploy-root must be a safe relative path"
  # A trailing slash creates an empty final component and makes equivalent
  # paths serialize differently.
  [[ "$value" != */ ]] || die "deploy-root must be a safe relative path"
  # Repeated slashes create empty interior components and ambiguous spelling.
  [[ "$value" != *//* ]] || die "deploy-root must be a safe relative path"

  rest="$value"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" == */* ]]; then
      component="${rest%%/*}"
      rest="${rest#*/}"
    else
      component="$rest"
      rest=""
    fi
    # Reject empty, current-directory, and parent-directory components so the
    # deploy source is always a normal subdirectory inside the worktree.
    [[ -n "$component" && "$component" != "." && "$component" != ".." ]] || die "deploy-root must be a safe relative path"
  done
}

# Git and repository helpers

git_ssh_command() {
  local key_path="${ssh_key_path:-}"
  local command

  [[ -n "$key_path" ]] || return 1

  # -i pins Git to the deployment-specific private key from config.
  command="ssh -i $(shell_quote "$key_path")"
  # IdentitiesOnly prevents ssh-agent or default keys from changing which
  # repository identity Git presents.
  command+=" -o IdentitiesOnly=yes"
  # BatchMode makes deploy/update fail instead of hanging on password or
  # passphrase prompts, which keeps unattended cron/API-triggered runs safe.
  command+=" -o BatchMode=yes"
  # accept-new preserves first-contact ergonomics while refusing changed host
  # keys after the first trust-on-first-use connection.
  command+=" -o StrictHostKeyChecking=accept-new"
  printf '%s\n' "$command"
}

git_with_auth() {
  local ssh_command

  if ssh_command="$(git_ssh_command)"; then
    GIT_SSH_COMMAND="$ssh_command" git "$@"
  else
    git "$@"
  fi
}

git_lfs_with_auth() {
  local ssh_command

  if ssh_command="$(git_ssh_command)"; then
    GIT_SSH_COMMAND="$ssh_command" git-lfs "$@"
  else
    git-lfs "$@"
  fi
}

ensure_helper() {
  local helper="$BIN_DIR/exchange-rename"
  local path_helper

  if [[ -x "$helper" ]]; then
    printf '%s\n' "$helper"
    return 0
  fi

  if path_helper="$(command -v exchange-rename 2>/dev/null)" && [[ -x "$path_helper" ]]; then
    printf '%s\n' "$path_helper"
    return 0
  fi

  [[ "$(uname -s)" == "Linux" ]] || die "exchange helper installation requires Linux; run on the site host, Linux CI, or a Linux container/VM"

  [[ -f "$HELPER_SOURCE" ]] || die "exchange helper source binary not found: $HELPER_SOURCE"
  cp "$HELPER_SOURCE" "$helper"
  chmod 755 "$helper"
  printf '%s\n' "$helper"
}

default_exclude_file() {
  local output="$1"

  # Defaults block common repository and credential material. Users can still
  # deploy dotfiles such as .htaccess and .well-known because those are not in
  # this list; .gitignore is excluded because it is repo bookkeeping, not site
  # content, in this deploy model.
  {
    printf '%s\n' '.git'
    printf '%s\n' '.git/'
    printf '%s\n' '.gitignore'
    printf '%s\n' '.gitattributes'
    printf '%s\n' '.gitmodules'
    printf '%s\n' '.github/'
    printf '%s\n' '.svn/'
    printf '%s\n' '.hg/'
    printf '%s\n' '.bzr/'
    printf '%s\n' '.aws/'
    printf '%s\n' '.ssh/'
    printf '%s\n' '.env'
    printf '%s\n' '.env.*'
    printf '%s\n' '.npmrc'
    printf '%s\n' '.pypirc'
    printf '%s\n' '.netrc'
    printf '%s\n' '.DS_Store'
  } >"$output"
}

# Release metadata and deploy orchestration

repo_dir_for() {
  local name="$1"
  printf '%s/%s\n' "$REPOS_DIR" "$name"
}

ensure_repo_cache() {
  local name="$1"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  if [[ -d "$repo_dir/.git" ]]; then
    git -C "$repo_dir" remote set-url origin "$repo_url"
  else
    rm -rf "$repo_dir"
    git_with_auth clone "$repo_url" "$repo_dir"
  fi
}

fetch_repo() {
  local name="$1"

  ensure_repo_cache "$name"
  git_with_auth -C "$(repo_dir_for "$name")" fetch --tags --prune origin
  git -C "$(repo_dir_for "$name")" gc --auto
}

resolve_ref() {
  local name="$1"
  local mode="$2"
  local value="$3"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  case "$mode" in
    branch)
      git -C "$repo_dir" rev-parse "refs/remotes/origin/$value^{commit}"
      ;;
    tag)
      git -C "$repo_dir" rev-parse "refs/tags/$value^{commit}"
      ;;
    commit)
      git -C "$repo_dir" rev-parse "$value^{commit}"
      ;;
    *)
      die "unknown ref mode: $mode"
      ;;
  esac
}

prepare_git_features() {
  local worktree="$1"
  local path
  local attr
  local uses_lfs=0
  local files_list="$TMP_DIR/git-files.$$.list"
  local attrs_list="$TMP_DIR/git-attrs.$$.list"
  local lfs_paths_list="$TMP_DIR/git-lfs-paths.$$.list"
  local lfs_pointer_paths="$TMP_DIR/git-lfs-pointers.$$.list"

  # Hydrate repository features that Git checkouts may leave incomplete for a
  # deployable filesystem: submodules first, then Git LFS objects.
  if [[ -f "$worktree/.gitmodules" ]]; then
    git_with_auth -C "$worktree" submodule update --init --recursive >&2
    if git -C "$worktree" submodule status --recursive | grep -Eq '^-'; then
      die "one or more submodules are uninitialized"
    fi
  fi

  # The deploy source is the checked-out filesystem, but LFS pointer files are
  # valid text files from Git's perspective. Detect LFS attributes and pull real
  # objects before copying into the docroot release tree.
  git -C "$worktree" ls-files -z >"$files_list"
  git -C "$worktree" check-attr filter --stdin -z <"$files_list" >"$attrs_list"
  : >"$lfs_paths_list"
  while IFS= read -r -d '' path && IFS= read -r -d '' _ && IFS= read -r -d '' attr; do
    if [[ "$attr" == "lfs" ]]; then
      uses_lfs=1
      printf '%s\0' "$path" >>"$lfs_paths_list"
    fi
  done <"$attrs_list"
  rm -f "$files_list" "$attrs_list"

  if ((uses_lfs)); then
    command -v git-lfs >/dev/null 2>&1 || die "git-lfs is required for repositories using Git LFS"
    (cd "$worktree" && git_lfs_with_auth install --local) >&2
    (cd "$worktree" && git_lfs_with_auth pull) >&2
    : >"$lfs_pointer_paths"
    while IFS= read -r -d '' path; do
      if grep -Il '^version https://git-lfs.github.com/spec/v1$' -- "$worktree/$path" >/dev/null 2>&1; then
        printf '%s\n' "$path" >>"$lfs_pointer_paths"
      fi
    done <"$lfs_paths_list"
    if [[ -s "$lfs_pointer_paths" ]]; then
      die "Git LFS pointer files remain after git lfs pull"
    fi
    rm -f "$lfs_pointer_paths"
  fi
  rm -f "$lfs_paths_list"
}

make_release_id() {
  local commit="$1"
  local random_hex

  # A release id names a deployment instance, not just Git content. The same
  # commit can be deployed more than once after rollback, config/deploy-root
  # changes, or a failed partial run, so a pure commit SHA would collide with
  # existing release and metadata paths. Keep the commit prefix for humans and
  # add a small random suffix for same-second redeploy uniqueness.
  random_hex="$(od -An -N2 -tx1 /dev/urandom | tr -d ' \n')"
  date -u "+%Y%m%d%H%M%S-${commit:0:12}-$random_hex"
}

create_worktree() {
  local name="$1"
  local commit="$2"
  local release_id="$3"
  local repo_dir
  local worktree

  repo_dir="$(repo_dir_for "$name")"
  worktree="$TMP_DIR/$name/$release_id/source"
  rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
  mkdir -p "$(dirname "$worktree")"

  git -C "$repo_dir" worktree prune
  git -C "$repo_dir" worktree add --detach "$worktree" "$commit" >&2
  if ! prepare_git_features "$worktree"; then
    cleanup_worktree_path "$repo_dir" "$worktree"
    rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
    rmdir "$TMP_DIR/$name" 2>/dev/null || true
    return 1
  fi
  printf '%s\n' "$worktree"
}

cleanup_worktree() {
  local name="$1"
  local worktree="$2"
  local release_id="$3"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  cleanup_worktree_path "$repo_dir" "$worktree"
  rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
  rmdir "$TMP_DIR/$name" 2>/dev/null || true
}

cleanup_worktree_path() {
  local repo_dir="$1"
  local worktree="$2"

  git -C "$repo_dir" worktree remove --force "$worktree" 2>/dev/null || rm -rf "$worktree"
  git -C "$repo_dir" worktree prune
}

copy_worktree_to_incoming() {
  local worktree="$1"
  local release_id="$2"
  local base
  local incoming
  local deploy_source="$worktree"
  local exclude_file="$TMP_DIR/excludes.$$.txt"
  local current_release=""
  local link_dest=""
  local rsync_args=()

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  incoming="$base/incoming/$release_id"

  # Stage the exact filesystem that will become the next release. deploy_root
  # makes a repository subdirectory behave as the docroot root, while link_dest
  # deduplicates unchanged files against the active release.
  if [[ -n "${deploy_root:-}" ]]; then
    deploy_source="$worktree/$deploy_root"
  fi
  if [[ ! -d "$deploy_source" ]]; then
    echo "wpcloud-site-git-deploy: deploy root does not exist or is not a directory: ${deploy_root:-.}" >&2
    return 1
  fi

  rm -rf "$incoming"
  mkdir -p "$incoming"
  default_exclude_file "$exclude_file"

  current_release="$(current_release_id || true)"
  if [[ -n "$current_release" && -d "$base/releases/$current_release" ]]; then
    link_dest="$base/releases/$current_release"
  fi

  rsync_args=(-a --delete --exclude-from="$exclude_file")
  if [[ -n "$link_dest" ]]; then
    rsync_args+=(--checksum --no-times --link-dest="$link_dest")
  fi
  rsync "${rsync_args[@]}" "$deploy_source/" "$incoming/"
  rm -f "$exclude_file"
}

write_release_metadata() {
  local release_id="$1"
  local mode="$2"
  local ref_value="$3"
  local commit="$4"
  local metadata_dir
  local metadata_file
  local key
  local value

  metadata_dir="$(docroot_deployment_base "$docroot" "$deployment_id")/metadata"
  metadata_file="$metadata_dir/$release_id.env"
  mkdir -p "$metadata_dir"
  {
    for key in "${RELEASE_METADATA_KEYS[@]}"; do
      case "$key" in
        release_id)
          value="$release_id"
          ;;
        ref_mode)
          value="$mode"
          ;;
        ref_value)
          value="$ref_value"
          ;;
        commit)
          value="$commit"
          ;;
        deploy_root)
          value="${deploy_root:-}"
          ;;
        deployed_at)
          value="$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
          ;;
        *)
          die "unmapped release metadata key: $key"
          ;;
      esac
      write_config_value "$key" "$value"
    done
  } >"$metadata_file"
}

metadata_key_allowed() {
  local key="$1"
  local allowed

  for allowed in "${RELEASE_METADATA_KEYS[@]}"; do
    [[ "$key" == "$allowed" ]] && return 0
  done
  return 1
}

metadata_unquote() {
  local value="$1"
  local output=""
  local char

  if [[ "$value" == "''" ]]; then
    printf '\n'
    return 0
  fi

  while [[ -n "$value" ]]; do
    char="${value:0:1}"
    value="${value:1}"
    if [[ "$char" == "\\" && -n "$value" ]]; then
      char="${value:0:1}"
      value="${value:1}"
    fi
    output+="$char"
  done
  printf '%s\n' "$output"
}

metadata_value() {
  local metadata_file="$1"
  local key="$2"
  local line
  local value

  metadata_key_allowed "$key" || return 1
  line="$(grep -m 1 -E "^${key}=" "$metadata_file" 2>/dev/null)" || return 0
  value="${line#*=}"
  metadata_unquote "$value"
}

current_release_metadata_file() {
  local current
  local metadata_file

  current="$(current_release_id || true)"
  [[ -n "$current" ]] || return 1
  metadata_file="$(docroot_deployment_base "$docroot" "$deployment_id")/metadata/$current.env"
  [[ -f "$metadata_file" ]] || return 1
  printf '%s\n' "$metadata_file"
}

current_release_matches() {
  local commit="$1"
  local expected_deploy_root="${2:-}"
  local metadata_file
  local metadata_commit
  local metadata_deploy_root

  metadata_file="$(current_release_metadata_file)" || return 1
  metadata_commit="$(metadata_value "$metadata_file" commit)"
  metadata_deploy_root="$(metadata_value "$metadata_file" deploy_root)"

  [[ "$metadata_commit" == "$commit" && "$metadata_deploy_root" == "$expected_deploy_root" ]]
}

run_engine_subshell() {
  (
    cmd_remote_deploy "$@"
  )
}

promote_release() {
  local release_id="$1"
  local helper="$2"
  local post_deploy_file="${3:-}"
  local maintenance_file_value="${4:-$DEFAULT_MAINTENANCE_FILE}"
  local engine_args=()

  engine_args=(
    --docroot "$docroot" \
    --deployment-id "$deployment_id" \
    --release-id "$release_id" \
    --keep-releases "$keep_releases" \
    --maintenance-file "$maintenance_file_value" \
    --exchange-helper "$helper"
  )
  if [[ -n "$post_deploy_file" ]]; then
    engine_args+=(--post-deploy-file "$post_deploy_file")
  fi

  run_engine_subshell "${engine_args[@]}"
}

deploy_ref() {
  local name="$1"
  local mode="$2"
  local value="$3"
  local force="${4:-0}"
  local post_deploy_override="${5:-}"
  local maintenance_file_override="${6:-}"
  local commit
  local release_id
  local worktree
  local helper
  local effective_post_deploy
  local effective_maintenance_file

  # High-level deploy pipeline: refresh cache, resolve the requested ref,
  # create a unique release instance, stage it into incoming, promote through
  # the internal engine, then persist metadata for inspection and no-op checks.
  load_config "$name"
  ensure_state_dirs
  helper="$(ensure_helper)"
  effective_post_deploy="${post_deploy_override:-${post_deploy:-}}"
  effective_maintenance_file="${maintenance_file_override:-${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}}"
  fetch_repo "$name"
  commit="$(resolve_ref "$name" "$mode" "$value")"
  if [[ "$force" != "1" ]] && current_release_matches "$commit" "${deploy_root:-}"; then
    printf 'no-op %s %s %s\n' "$(current_release_id)" "$mode" "$commit"
    return 0
  fi
  release_id="$(make_release_id "$commit")"
  worktree="$(create_worktree "$name" "$commit" "$release_id")"
  if ! copy_worktree_to_incoming "$worktree" "$release_id"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  if ! promote_release "$release_id" "$helper" "$effective_post_deploy" "$effective_maintenance_file"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  if ! write_release_metadata "$release_id" "$mode" "$value" "$commit"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  cleanup_worktree "$name" "$worktree" "$release_id"
  printf '%s %s %s\n' "$release_id" "$mode" "$commit"
}

current_release_id() {
  local current

  current="$(docroot_deployment_base "$docroot" "$deployment_id")/current"
  [[ -L "$current" ]] || return 1
  readlink "$current" | sed 's#^releases/##'
}

select_rollback_release() {
  local base
  local current="${1:-}"
  local metadata_file
  local release_name
  local metadata_candidates="$TMP_DIR/rollback-candidates.$$.txt"

  # Failed deployments can leave a release directory behind after incoming is
  # moved but before current is switched. Success metadata is written only after
  # promotion completes, so default rollback should prefer metadata-backed
  # releases instead of blindly picking the newest directory.
  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  : >"$metadata_candidates"
  find "$base/metadata" -mindepth 1 -maxdepth 1 -type f -name '*.env' 2>/dev/null |
    while IFS= read -r metadata_file; do
      release_name="${metadata_file##*/}"
      release_name="${release_name%.env}"
      [[ "$release_name" == "$current" ]] && continue
      [[ -d "$base/releases/$release_name" ]] || continue
      printf '%s\n' "$base/releases/$release_name"
    done >"$metadata_candidates"

  if [[ -s "$metadata_candidates" ]]; then
    xargs ls -dt <"$metadata_candidates" 2>/dev/null |
      head -n 1 |
      xargs basename
    rm -f "$metadata_candidates"
    return 0
  fi
  rm -f "$metadata_candidates"

  find "$base/releases" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
    while IFS= read -r path; do
      [[ "${path##*/}" == "$current" ]] && continue
      printf '%s\n' "$path"
    done |
    xargs ls -dt 2>/dev/null |
    head -n 1 |
    xargs basename
}

repo_host_from_url() {
  local url="$1"

  if [[ "$url" =~ ^[^@:/]+@([^:/]+):.+$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$url" =~ ^ssh://[^@]+@([^/]+)/.+$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$url" =~ ^https://([^/]+)/.+$ ]]; then
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ -d "$url" || "$url" == /* || "$url" == ./* || "$url" == ../* ]]; then
    printf 'local\n'
    return 0
  fi
  return 1
}

https_to_ssh() {
  local url="$1"
  local host
  local path

  [[ "$url" =~ ^https://([^/]+)/(.+)$ ]] || return 1
  host="${BASH_REMATCH[1]}"
  path="${BASH_REMATCH[2]}"
  path="${path#/}"
  [[ -n "$host" ]] || return 1
  [[ -n "$path" ]] || return 1
  printf 'git@%s:%s\n' "$host" "$path"
}

repo_url_supports_auth() {
  local url="$1"

  [[ "$url" =~ ^[^@:/]+@[^:/]+:.+$ || "$url" =~ ^ssh://[^@]+@[^/]+/.+$ ]]
}

private_key_mode() {
  local path="$1"

  stat -c '%a' "$path"
}

private_key_public_key() {
  local path="$1"

  ssh-keygen -y -f "$path" </dev/null 2>/dev/null
}

require_ssh_keygen_for_keys() {
  command -v ssh-keygen >/dev/null 2>&1 || die "ssh-keygen is required to validate deploy keys"
}

validate_existing_private_key() {
  local path="$1"
  local mode

  require_ssh_keygen_for_keys
  [[ -f "$path" ]] || die "private key is missing: $path"
  [[ -r "$path" ]] || die "private key is not readable: $path"
  mode="$(private_key_mode "$path")"
  if (( (8#$mode) & 0077 )); then
    die "private key permissions are too open: $mode"
  fi
  private_key_public_key "$path" >/dev/null || die "private key cannot be used without prompting or is not a valid private key: $path"
}

derive_public_key_file() {
  local private_key="$1"
  local public_key_path="$2"
  local tmp

  require_ssh_keygen_for_keys
  tmp="$(mktemp "${public_key_path}.tmp.XXXXXX")"
  if ! private_key_public_key "$private_key" >"$tmp"; then
    rm -f "$tmp"
    die "private key cannot be used without prompting or is not a valid private key: $private_key"
  fi
  mv "$tmp" "$public_key_path"
  chmod 644 "$public_key_path"
}

same_file() {
  local left="$1"
  local right="$2"

  [[ -e "$left" && -e "$right" ]] || return 1
  [[ "$(cd "$(dirname "$left")" && pwd -P)/$(basename "$left")" == "$(cd "$(dirname "$right")" && pwd -P)/$(basename "$right")" ]]
}

doctor_failures=0

doctor_ok() {
  printf 'OK %s: %s\n' "$1" "$2"
}

doctor_warn() {
  printf 'WARN %s: %s\n' "$1" "$2"
}

doctor_fail() {
  printf 'FAIL %s: %s\n' "$1" "$2"
  doctor_failures=$((doctor_failures + 1))
}

# Public command handlers

cmd_auth() {
  local name="${1:-}"
  shift || true
  local force_new_key=0
  local verify=0
  local remove=0
  local purge_key=0
  local key_path
  local use_key=""
  local import_key=""
  local host
  local public_key

  # Configure exactly one deploy key source for this deployment: generated
  # managed key, external key path, imported managed copy, or removal.
  require_name "$name"
  while (($#)); do
    case "$1" in
      --force-new-key)
        force_new_key=1
        shift
        ;;
      --verify)
        verify=1
        shift
        ;;
      --remove)
        remove=1
        shift
        ;;
      --purge-key)
        purge_key=1
        shift
        ;;
      --use-key)
        use_key="${2:-}"
        shift 2
        ;;
      --import-key)
        import_key="${2:-}"
        shift 2
        ;;
      *)
        die "unknown auth argument: $1"
        ;;
    esac
  done

  load_config "$name"
  ensure_state_dirs

  if ((remove)); then
    if ((verify || force_new_key)) || [[ -n "$use_key" || -n "$import_key" ]]; then
      die "--remove cannot be combined with --verify, --force-new-key, --use-key, or --import-key"
    fi
    key_path="${ssh_key_path:-}"
    ssh_key_path=""
    write_config "$name"
    printf 'Removed deploy key configuration for %s\n' "$name"
    if ((purge_key)); then
      if [[ -n "$key_path" && "$key_path" == "$KEYS_DIR"/* ]]; then
        rm -f "$key_path" "$key_path.pub"
        printf 'Deleted deploy key files for %s\n' "$name"
      elif [[ -n "$key_path" ]]; then
        printf 'Did not delete external key files: %s\n' "$key_path"
      else
        printf 'No deploy key files configured for %s\n' "$name"
      fi
    fi
    return 0
  fi

  if ((purge_key)); then
    die "--purge-key requires --remove"
  fi
  if [[ -n "$use_key" && -n "$import_key" ]]; then
    die "choose only one deploy key source"
  fi
  if [[ -n "$use_key" && "$force_new_key" -eq 1 ]]; then
    die "--force-new-key can only be used with generated or imported keys"
  fi

  if [[ "$repo_url" =~ ^https:// ]]; then
    repo_url="$(https_to_ssh "$repo_url")" || die "could not convert HTTPS URL to SSH"
  fi
  repo_url_supports_auth "$repo_url" || die "repository URL is not a Git SSH or HTTPS URL: $repo_url"

  key_path="$KEYS_DIR/${name}_ed25519"
  if [[ -n "$use_key" ]]; then
    validate_existing_private_key "$use_key"
    key_path="$use_key"
    public_key="$(private_key_public_key "$key_path")"
    printf 'Using existing deploy key: %s\n' "$key_path"
  elif [[ -n "$import_key" ]]; then
    validate_existing_private_key "$import_key"
    if same_file "$import_key" "$key_path"; then
      die "cannot import the managed deploy key onto itself: $key_path"
    fi
    if [[ -e "$key_path" && "$force_new_key" -ne 1 ]]; then
      die "managed deploy key already exists: $key_path; use --force-new-key to replace it or --use-key PATH to reference an existing key without copying"
    fi
    rm -f "$key_path" "$key_path.pub"
    mkdir -p "$KEYS_DIR"
    chmod 700 "$KEYS_DIR"
    cp "$import_key" "$key_path"
    chmod 600 "$key_path"
    derive_public_key_file "$key_path" "$key_path.pub"
    public_key="$(cat "$key_path.pub")"
    printf 'Imported deploy key: %s\n' "$key_path"
  else
    if ((force_new_key)); then
      rm -f "$key_path" "$key_path.pub"
    fi
    if [[ -f "$key_path" ]]; then
      printf 'Reusing existing deploy key: %s\n' "$key_path"
    else
      command -v ssh-keygen >/dev/null 2>&1 || die "ssh-keygen is required to create a deploy key"
      mkdir -p "$KEYS_DIR"
      chmod 700 "$KEYS_DIR"
      (umask 077 && ssh-keygen -t ed25519 -N '' -C "wpcloud-site-git-deploy:$name" -f "$key_path" >/dev/null)
      chmod 600 "$key_path"
      chmod 644 "$key_path.pub"
      printf 'Created deploy key: %s\n' "$key_path"
    fi
    validate_existing_private_key "$key_path"
    if [[ -f "$key_path.pub" ]]; then
      public_key="$(cat "$key_path.pub")"
    else
      derive_public_key_file "$key_path" "$key_path.pub"
      public_key="$(cat "$key_path.pub")"
    fi
  fi

  ssh_key_path="$key_path"
  write_config "$name"
  host="$(repo_host_from_url "$repo_url" || true)"

  if [[ "$host" == "github.com" ]]; then
    printf 'Add this public key as a read-only GitHub deploy key for %s:\n' "$repo_url"
  else
    printf 'Add this public key to the repository host for %s with read-only access to %s:\n' "$host" "$repo_url"
  fi
  printf '%s\n' "$public_key"
  printf 'After adding the key, run: wpcloud-site-git-deploy doctor %s\n' "$name"

  if ((verify)); then
    git_with_auth ls-remote "$repo_url" HEAD >/dev/null || die "remote access failed; add the public key to the repository and try again"
    printf 'Verified remote access for %s\n' "$repo_url"
  fi
}

cmd_doctor() {
  local name="${1:-}"
  shift || true
  local offline=0
  local command_name
  local mode
  local host
  local repo_dir
  local helper

  # Report every setup problem found instead of failing on the first one so a
  # first-time user gets a complete repair checklist.
  require_name "$name"
  while (($#)); do
    case "$1" in
      --offline)
        offline=1
        shift
        ;;
      *)
        die "unknown doctor argument: $1"
        ;;
    esac
  done

  doctor_failures=0
  if load_config "$name"; then
    doctor_ok config "deployment loaded"
  else
    doctor_fail config "deployment is not initialized"
    return 1
  fi

  for command_name in bash git rsync find flock sort comm cut grep cat readlink ln rm mv mkdir mktemp touch stat date; do
    if command -v "$command_name" >/dev/null 2>&1; then
      doctor_ok command "$command_name found"
    else
      doctor_fail command "$command_name is required"
    fi
  done
  if command -v ssh-keygen >/dev/null 2>&1; then
    doctor_ok command "ssh-keygen found"
  else
    doctor_warn command "ssh-keygen not found; auth and configured key validation will be unavailable"
  fi

  if [[ -d "$docroot" ]]; then
    doctor_ok docroot "exists: $docroot"
    if [[ -w "$docroot" ]]; then
      doctor_ok docroot "writable: $docroot"
    else
      doctor_fail docroot "not writable: $docroot"
    fi
  else
    doctor_fail docroot "does not exist: $docroot"
  fi

  if repo_host_from_url "$repo_url" >/dev/null 2>&1; then
    host="$(repo_host_from_url "$repo_url")"
    doctor_ok repo "recognized host: $host"
  else
    doctor_fail repo "could not parse repository URL: $repo_url"
  fi

  if helper="$(ensure_helper 2>/dev/null)" && [[ -x "$helper" ]]; then
    doctor_ok helper "exchange-rename available: $helper"
  else
    doctor_fail helper "exchange-rename helper is not available"
  fi

  if [[ -z "${ssh_key_path:-}" ]]; then
    doctor_warn ssh-key "no deploy key configured; Git will use default credentials or public repository access"
  elif [[ ! -f "$ssh_key_path" ]]; then
    doctor_fail ssh-key "private key is missing: $ssh_key_path"
  elif [[ ! -r "$ssh_key_path" ]]; then
    doctor_fail ssh-key "private key is not readable: $ssh_key_path"
  else
    mode="$(private_key_mode "$ssh_key_path")"
    if (( (8#$mode) & 0077 )); then
      doctor_fail ssh-key "private key permissions are too open: $mode"
    else
      doctor_ok ssh-key "private key is readable"
      if ! command -v ssh-keygen >/dev/null 2>&1; then
        doctor_fail ssh-key "ssh-keygen is required to validate deploy keys"
      elif private_key_public_key "$ssh_key_path" >/dev/null; then
        if [[ -f "$ssh_key_path.pub" ]]; then
          doctor_ok ssh-key "public key exists"
        else
          doctor_ok ssh-key "public key can be derived"
        fi
      else
        doctor_fail ssh-key "private key cannot be used without prompting or is not a valid private key: $ssh_key_path"
      fi
    fi
  fi

  repo_dir="$(repo_dir_for "$name")"
  if [[ -d "$repo_dir/.git" ]] && git -C "$repo_dir" grep -q 'filter=lfs' HEAD -- .gitattributes >/dev/null 2>&1; then
    if command -v git-lfs >/dev/null 2>&1; then
      doctor_ok git-lfs "available for cached LFS-tracked repository"
    else
      doctor_fail git-lfs "git-lfs is required for cached LFS-tracked repository"
    fi
  else
    doctor_warn git-lfs "not checked; no root .gitattributes LFS marker found in cached HEAD"
  fi

  if ((offline)); then
    doctor_warn git-remote "skipped remote access check because --offline was provided"
  elif git_with_auth ls-remote "$repo_url" HEAD >/dev/null 2>&1; then
    doctor_ok git-remote "remote access succeeded"
  elif [[ -z "${ssh_key_path:-}" ]]; then
    doctor_fail git-remote "remote access failed without a configured deploy key; run auth for private SSH repositories or check repository access"
  else
    doctor_fail git-remote "remote access failed; add the deploy key to the repository host or check repository access"
  fi

  ((doctor_failures == 0))
}

cmd_config() {
  local name="${1:-}"
  shift || true
  local set_deploy_root=""
  local clear_deploy_root=0
  local set_post_deploy=""
  local set_post_deploy_provided=0
  local clear_post_deploy=0
  local set_maintenance_file=""
  local set_maintenance_file_provided=0
  local selected=0

  require_name "$name"
  while (($#)); do
    case "$1" in
      --deploy-root)
        set_deploy_root="${2:-}"
        shift 2
        ;;
      --clear-deploy-root)
        clear_deploy_root=1
        shift
        ;;
      --post-deploy)
        set_post_deploy="${2:-}"
        set_post_deploy_provided=1
        shift 2
        ;;
      --clear-post-deploy)
        clear_post_deploy=1
        shift
        ;;
      --maintenance-file)
        set_maintenance_file="${2:-}"
        set_maintenance_file_provided=1
        shift 2
        ;;
      *)
        die "unknown config argument: $1"
        ;;
    esac
  done

  [[ -n "$set_deploy_root" ]] && selected=$((selected + 1))
  [[ "$clear_deploy_root" -eq 1 ]] && selected=$((selected + 1))
  [[ "$set_post_deploy_provided" -eq 1 ]] && selected=$((selected + 1))
  [[ "$clear_post_deploy" -eq 1 ]] && selected=$((selected + 1))
  [[ "$set_maintenance_file_provided" -eq 1 ]] && selected=$((selected + 1))
  [[ "$selected" -gt 0 ]] || die "config requires --deploy-root, --clear-deploy-root, --post-deploy, --clear-post-deploy, or --maintenance-file"
  [[ "$selected" -eq 1 ]] || die "choose only one config option"

  load_config "$name"
  if [[ -n "$set_deploy_root" ]]; then
    require_deploy_root "$set_deploy_root"
    deploy_root="$set_deploy_root"
    write_config "$name"
    printf 'configured %s deploy_root=%s\n' "$name" "$deploy_root"
  elif [[ "$clear_deploy_root" -eq 1 ]]; then
    deploy_root=""
    write_config "$name"
    printf 'cleared %s deploy_root\n' "$name"
  elif [[ "$set_post_deploy_provided" -eq 1 ]]; then
    require_post_deploy_path "$set_post_deploy"
    post_deploy="$set_post_deploy"
    write_config "$name"
    printf 'configured %s post_deploy=%s\n' "$name" "$post_deploy"
  elif [[ "$clear_post_deploy" -eq 1 ]]; then
    post_deploy=""
    write_config "$name"
    printf 'cleared %s post_deploy\n' "$name"
  else
    require_maintenance_file "$set_maintenance_file"
    maintenance_file="$set_maintenance_file"
    write_config "$name"
    printf 'configured %s maintenance_file=%s\n' "$name" "$maintenance_file"
  fi
}

cmd_init() {
  local name="${1:-}"
  shift || true
  local repo=""
  local init_docroot=""
  local init_deployment_id=""
  local init_default_ref=""
  local init_keep_releases="$DEFAULT_KEEP_RELEASES"
  local init_deploy_root=""
  local init_maintenance_file="$DEFAULT_MAINTENANCE_FILE"

  require_name "$name"
  while (($#)); do
    case "$1" in
      --repo)
        repo="${2:-}"
        shift 2
        ;;
      --docroot)
        init_docroot="${2:-}"
        shift 2
        ;;
      --deployment-id)
        init_deployment_id="${2:-}"
        shift 2
        ;;
      --default-ref)
        init_default_ref="${2:-}"
        shift 2
        ;;
      --keep-releases)
        init_keep_releases="${2:-}"
        shift 2
        ;;
      --deploy-root)
        init_deploy_root="${2:-}"
        shift 2
        ;;
      --maintenance-file)
        init_maintenance_file="${2:-}"
        shift 2
        ;;
      *)
        die "unknown init argument: $1"
        ;;
    esac
  done

  [[ -n "$repo" ]] || die "--repo is required"
  [[ -n "$init_docroot" ]] || die "--docroot is required"
  [[ -n "$init_deployment_id" ]] || die "--deployment-id is required"
  [[ -n "$init_default_ref" ]] || die "--default-ref is required"
  require_id "$init_deployment_id"
  [[ "$init_keep_releases" =~ ^[0-9]+$ && "$init_keep_releases" -ge 1 ]] || die "--keep-releases must be a positive integer"
  if [[ -n "$init_deploy_root" ]]; then
    require_deploy_root "$init_deploy_root"
  fi
  require_maintenance_file "$init_maintenance_file"

  ensure_state_dirs
  ensure_helper >/dev/null
  repo_url="$repo"
  docroot="$init_docroot"
  deployment_id="$init_deployment_id"
  default_ref="$init_default_ref"
  keep_releases="$init_keep_releases"
  deploy_root="$init_deploy_root"
  maintenance_file="$init_maintenance_file"
  ssh_key_path=""
  write_config "$name"
  printf 'initialized %s\n' "$name"
}

cmd_deploy() {
  local name="${1:-}"
  shift || true
  local mode=""
  local value=""
  local force=0
  local post_deploy_override=""
  local maintenance_file_override=""

  require_name "$name"
  while (($#)); do
    case "$1" in
      --branch)
        [[ -z "$mode" ]] || die "choose only one ref"
        mode="branch"
        value="${2:-}"
        shift 2
        ;;
      --tag)
        [[ -z "$mode" ]] || die "choose only one ref"
        mode="tag"
        value="${2:-}"
        shift 2
        ;;
      --commit)
        [[ -z "$mode" ]] || die "choose only one ref"
        mode="commit"
        value="${2:-}"
        shift 2
        ;;
      --force)
        force=1
        shift
        ;;
      --post-deploy)
        post_deploy_override="${2:-}"
        require_post_deploy_path "$post_deploy_override"
        shift 2
        ;;
      --maintenance-file)
        maintenance_file_override="${2:-}"
        require_maintenance_file "$maintenance_file_override"
        shift 2
        ;;
      *)
        die "unknown deploy argument: $1"
        ;;
    esac
  done

  [[ -n "$mode" && -n "$value" ]] || die "deploy requires --branch, --tag, or --commit"
  deploy_ref "$name" "$mode" "$value" "$force" "$post_deploy_override" "$maintenance_file_override"
}

cmd_update() {
  local name="${1:-}"
  shift || true
  local force=0
  local post_deploy_override=""
  local maintenance_file_override=""

  require_name "$name"
  while (($#)); do
    case "$1" in
      --force)
        force=1
        shift
        ;;
      --post-deploy)
        post_deploy_override="${2:-}"
        require_post_deploy_path "$post_deploy_override"
        shift 2
        ;;
      --maintenance-file)
        maintenance_file_override="${2:-}"
        require_maintenance_file "$maintenance_file_override"
        shift 2
        ;;
      *)
        die "unknown update argument: $1"
        ;;
    esac
  done

  load_config "$name"
  deploy_ref "$name" branch "$default_ref" "$force" "$post_deploy_override" "$maintenance_file_override"
}

cmd_rollback() {
  local name="${1:-}"
  shift || true
  local to=""
  local helper
  local current

  while (($#)); do
    case "$1" in
      --to)
        to="${2:-}"
        shift 2
        ;;
      *)
        die "unknown rollback argument: $1"
        ;;
    esac
  done

  load_config "$name"
  helper="$(ensure_helper)"
  current="$(current_release_id || true)"
  if [[ -z "$to" ]]; then
    to="$(select_rollback_release "$current")"
  fi
  [[ -n "$to" ]] || die "no rollback release available"
  run_engine_subshell --docroot "$docroot" --deployment-id "$deployment_id" --rollback-to "$to" --maintenance-file "$maintenance_file" --exchange-helper "$helper"
  printf 'rolled back to %s\n' "$to"
}

cmd_releases() {
  local name="${1:-}"
  local base
  local current
  local release
  local metadata
  local commit
  local ref_mode
  local ref_value
  local deploy_root

  load_config "$name"
  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  current="$(current_release_id || true)"
  find "$base/releases" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -r |
  while IFS= read -r release; do
    metadata="$base/metadata/${release##*/}.env"
    printf '%s' "${release##*/}"
    [[ "${release##*/}" == "$current" ]] && printf ' current'
    if [[ -f "$metadata" ]]; then
      commit="$(metadata_value "$metadata" commit)"
      ref_mode="$(metadata_value "$metadata" ref_mode)"
      ref_value="$(metadata_value "$metadata" ref_value)"
      deploy_root="$(metadata_value "$metadata" deploy_root)"
      printf ' %s %s' "${commit:-unknown}" "${ref_mode:-unknown}:${ref_value:-unknown}"
      if [[ -n "${deploy_root:-}" ]]; then
        printf ' deploy-root:%s' "$deploy_root"
      fi
    fi
    printf '\n'
  done
}

cmd_branches() {
  local name="${1:-}"
  shift || true
  local limit=20
  local fetch=0
  while (($#)); do
    case "$1" in
      --fetch)
        fetch=1
        shift
        ;;
      --limit)
        limit="${2:-}"
        shift 2
        ;;
      *)
        die "unknown branches argument: $1"
        ;;
    esac
  done
  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" for-each-ref refs/remotes/origin --format='%(refname:short)' --sort=-committerdate |
    sed 's#^origin/##' |
    grep -v '^HEAD$' |
    head -n "$limit"
}

cmd_tags() {
  local name="${1:-}"
  shift || true
  local limit=20
  local fetch=0
  while (($#)); do
    case "$1" in
      --fetch)
        fetch=1
        shift
        ;;
      --limit)
        limit="${2:-}"
        shift 2
        ;;
      *)
        die "unknown tags argument: $1"
        ;;
    esac
  done
  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" for-each-ref refs/tags --format='%(refname:short)' --sort=-creatordate |
    head -n "$limit"
}

cmd_commits() {
  local name="${1:-}"
  shift || true
  local limit=20
  local fetch=0
  while (($#)); do
    case "$1" in
      --fetch)
        fetch=1
        shift
        ;;
      --limit)
        limit="${2:-}"
        shift 2
        ;;
      *)
        die "unknown commits argument: $1"
        ;;
    esac
  done
  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" log --format='%H %s' -n "$limit" "origin/$default_ref"
}

cmd_status() {
  local name="${1:-}"
  load_config "$name"
  printf 'name=%s\n' "$name"
  printf 'repo=%s\n' "$repo_url"
  printf 'docroot=%s\n' "$docroot"
  printf 'deployment_id=%s\n' "$deployment_id"
  printf 'default_ref=%s\n' "$default_ref"
  printf 'keep_releases=%s\n' "$keep_releases"
  printf 'deploy_root=%s\n' "${deploy_root:-}"
  printf 'post_deploy=%s\n' "${post_deploy:-}"
  printf 'maintenance_file=%s\n' "${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}"
  printf 'current=%s\n' "$(current_release_id || true)"
}

# Internal promotion engine

engine_usage() {
  cat <<-'USAGE'
	Usage: wpcloud-site-git-deploy __remote-deploy --docroot PATH --deployment-id ID --release-id ID --keep-releases N [--exchange-helper PATH] [--post-deploy-file PATH] [--maintenance-file PATH|none] [--print-claims]
	       wpcloud-site-git-deploy __remote-deploy --docroot PATH --deployment-id ID --rollback-to RELEASE_ID [--exchange-helper PATH] [--maintenance-file PATH|none]
	       wpcloud-site-git-deploy __remote-deploy --docroot PATH --assert-public-symlinks

	Promote an uploaded incoming release into the deployment namespace and update current.

	Options:
	  --post-deploy-file PATH
	                  Run this bash command file from the docroot after current is
	                  updated and stale symlinks are cleaned up. Failure exits
	                  nonzero without rolling back the active release.
	  --maintenance-file PATH|none
	                  Create a tool-owned WordPress maintenance marker during
	                  promotion or rollback. Use none to disable.
	  --print-claims  Print compressed claims for the incoming release and exit without
	                  promoting the release or changing current.
	  --rollback-to RELEASE_ID
	                  Re-point current to an existing release and reconcile managed
	                  public symlinks. Post-deploy commands are not run.
	  --exchange-helper PATH
	                  Helper binary that atomically swaps two paths with
	                  renameat2(RENAME_EXCHANGE). Defaults to the uploaded helper in
	                  the deployment namespace.
	  --assert-public-symlinks
	                  Validate that public symlink targets are relative and resolve
	                  under the docroot. This is an invariant check for the SSH CLI,
	                  where $HOME is not mounted during HTTP requests.
	USAGE
}

engine_die() {
  echo "wpcloud-site-git-deploy __remote-deploy: $*" >&2
  exit 64
}

trim() {
  local value="$1"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

engine_require_id() {
  local name="$1"
  local value="$2"

  [[ "$value" =~ ^[a-z0-9][a-z0-9-]*$ ]] || engine_die "$name must be a normalized id"
}

RUN_SCRATCH_DIR=""

cleanup_run_scratch() {
  if [[ -n "$RUN_SCRATCH_DIR" ]]; then
    rm -rf -- "$RUN_SCRATCH_DIR" 2>/dev/null || true
  fi
}

maintenance_file_enabled() {
  local maintenance_file="$1"

  [[ -n "$maintenance_file" && "$maintenance_file" != "none" ]]
}

maintenance_path() {
  local docroot="$1"
  local maintenance_file="$2"

  printf '%s/%s\n' "$docroot" "$maintenance_file"
}

maintenance_file_is_tool_owned() {
  local path="$1"
  local deployment_id="$2"

  [[ ! -L "$path" && -f "$path" ]] || return 1
  {
    grep -Fxq "wpcloud-site-git-deploy maintenance" "$path" ||
      grep -Fxq "// wpcloud-site-git-deploy maintenance" "$path"
  } || return 1
  {
    grep -Fxq "deployment_id=$deployment_id" "$path" ||
      grep -Fxq "// deployment_id=$deployment_id" "$path"
  } || return 1
}

cleanup_owned_maintenance_file() {
  local docroot="$1"
  local deployment_id="$2"
  local maintenance_file="$3"
  local path

  maintenance_file_enabled "$maintenance_file" || return 0
  path="$(maintenance_path "$docroot" "$maintenance_file")"
  if maintenance_file_is_tool_owned "$path" "$deployment_id"; then
    rm -f -- "$path"
  fi
}

create_maintenance_file() {
  local docroot="$1"
  local deployment_id="$2"
  local release_id="$3"
  local maintenance_file="$4"
  local path
  local parent
  local tmp_path

  maintenance_file_enabled "$maintenance_file" || return 0

  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  path="$(maintenance_path "$docroot" "$maintenance_file")"
  [[ ! -e "$path" && ! -L "$path" ]] || return 0

  parent="${path%/*}"
  [[ -d "$parent" ]] || engine_die "maintenance-file parent does not exist: ${maintenance_file%/*}"

  tmp_path="$path.$$"
  rm -f -- "$tmp_path"
  {
    printf '<?php\n'
    printf '%s\n' "\$upgrading = $(date +%s);"
    printf '// wpcloud-site-git-deploy maintenance\n'
    printf '// deployment_id=%s\n' "$deployment_id"
    printf '// release_id=%s\n' "$release_id"
    printf '// created_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } >"$tmp_path"
  mv -T "$tmp_path" "$path"
}

ENGINE_MAINTENANCE_DOCROOT=""
ENGINE_MAINTENANCE_DEPLOYMENT_ID=""
ENGINE_MAINTENANCE_FILE="none"

cleanup_engine_exit() {
  cleanup_run_scratch
  if [[ -n "$ENGINE_MAINTENANCE_DOCROOT" && -n "$ENGINE_MAINTENANCE_DEPLOYMENT_ID" ]]; then
    cleanup_owned_maintenance_file \
      "$ENGINE_MAINTENANCE_DOCROOT" \
      "$ENGINE_MAINTENANCE_DEPLOYMENT_ID" \
      "$ENGINE_MAINTENANCE_FILE"
  fi
}

require_remote_capabilities() {
  local command_name
  local probe_dir

  for command_name in readlink flock find sort comm cut grep cat ln rm mv mkdir mktemp touch date; do
    command -v "$command_name" >/dev/null 2>&1 || engine_die "$command_name is required"
  done

  # Later pruning depends on GNU find's timestamp output, and sticky/protected
  # discovery uses GNU-style predicates. Probing -printf is the cheap proxy for
  # GNU find as a whole.
  probe_dir="$(mktemp -d "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-preflight.XXXXXX")" || engine_die "mktemp is required"
  if ! find "$probe_dir" -mindepth 1 -maxdepth 1 -type d -printf '%T@\t%p\n' >/dev/null 2>&1; then
    rm -rf -- "$probe_dir"
    engine_die "GNU find with -printf is required"
  fi

  : >"$probe_dir/source"
  if ! mv -T "$probe_dir/source" "$probe_dir/dest" 2>/dev/null; then
    rm -rf -- "$probe_dir"
    engine_die "atomic replacement requires mv -T"
  fi
  rm -rf -- "$probe_dir"
}

assert_public_symlinks_under_docroot() {
  local docroot="$1"
  local deployment_filter="${2:-}"
  local docroot_real
  local link_path
  local target
  local owner
  local parent_real
  local target_dir
  local target_base
  local resolved_dir
  local resolved
  local home_value="${HOME:-}"
  local links_tmp

  docroot_real="$(cd "$docroot" && pwd -P)" || engine_die "docroot does not exist: $docroot"

  # Public symlinks must be usable by HTTP. On WP Cloud, $HOME exists in SSH
  # sessions but is not mounted for web requests, so any target outside docroot
  # is a broken deployment even if it works over SSH.
  links_tmp="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-links.XXXXXX")" || engine_die "mktemp is required"
  find "$docroot" -path "$docroot/$DOCROOT_NAMESPACE" -prune -o -type l -print0 >"$links_tmp" 2>/dev/null || true
  while IFS= read -r -d '' link_path; do
    target="$(readlink "$link_path")"

    if [[ -n "$deployment_filter" ]]; then
      if ! owner="$(deployment_owner_from_target "$target")" || [[ "$owner" != "$deployment_filter" ]]; then
        continue
      fi
    fi

    [[ "$target" != /* ]] || engine_die "public symlink target is absolute: ${link_path#"$docroot"/}"
    if [[ -n "$home_value" && "$target" == *"$home_value"* ]]; then
      engine_die "public symlink target contains HOME: ${link_path#"$docroot"/}"
    fi

    parent_real="$(cd "$(dirname "$link_path")" && pwd -P)" || engine_die "could not resolve public symlink parent: ${link_path#"$docroot"/}"
    target_dir="$(dirname "$target")"
    target_base="$(basename "$target")"
    resolved_dir="$(cd "$parent_real/$target_dir" 2>/dev/null && pwd -P)" || engine_die "public symlink resolves outside docroot: ${link_path#"$docroot"/}"
    resolved="$resolved_dir/$target_base"

    case "$resolved" in
      "$docroot_real"/*)
        ;;
      *)
        engine_die "public symlink resolves outside docroot: ${link_path#"$docroot"/}"
        ;;
    esac
  done <"$links_tmp"
  rm -f -- "$links_tmp"
}

resolve_path() {
  local path="$1"

  readlink -f "$path"
}

assert_claim_symlinks_under_docroot() {
  local docroot="$1"
  local claims_file="$2"
  local docroot_real
  local claim
  local public_path
  local target
  local resolved
  local home_value="${HOME:-}"

  docroot_real="$(resolve_path "$docroot")" || engine_die "docroot does not exist: $docroot"

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    [[ -n "$claim" ]] || continue
    public_path="$docroot/$claim"

    [[ -L "$public_path" ]] || engine_die "public claim is not a symlink: $claim"
    target="$(readlink "$public_path")"

    [[ "$target" != /* ]] || engine_die "public symlink target is absolute: $claim"
    if [[ -n "$home_value" && "$target" == *"$home_value"* ]]; then
      engine_die "public symlink target contains HOME: $claim"
    fi

    resolved="$(resolve_path "$public_path")" || engine_die "public symlink resolves outside docroot: $claim"
    case "$resolved" in
      "$docroot_real"/*)
        ;;
      *)
        engine_die "public symlink resolves outside docroot: $claim"
        ;;
    esac
  done <"$claims_file"
}

create_scratch_dir() {
  local base="$1"

  cleanup_run_scratch
  RUN_SCRATCH_DIR="$(mktemp -d "$base/.tmp.XXXXXX")" || engine_die "could not create scratch directory under $base"
  printf '%s\n' "$RUN_SCRATCH_DIR"
}

sweep_stale_scratch_dirs() {
  local base="$1"
  local scratch_path

  { find "$base" -mindepth 1 -maxdepth 1 -type d -name '.tmp.*' -print0 2>/dev/null || true; } |
  while IFS= read -r -d '' scratch_path; do
    rm -rf -- "$scratch_path"
  done
}

switch_current() {
  local base="$1"
  local release_id="$2"
  local current="$base/current"
  local tmp_current="$base/.current.$release_id.$$"

  rm -f "$tmp_current"
  ln -s "releases/$release_id" "$tmp_current"

  # Every public symlink points through current. Replacing current must therefore
  # be a single rename, never remove-then-create.
  if mv -T "$tmp_current" "$current" 2>/dev/null; then
    return 0
  fi

  rm -f "$tmp_current"
  engine_die "atomic current replacement requires mv -T"
}

acquire_lock() {
  local lock_file="$1"

  # fd 9 is just a private lock handle. There is no explicit unlock: the kernel
  # releases the flock when this process exits and closes the descriptor.
  exec 9>"$lock_file"
  flock -n -x 9 || engine_die "deployment already running"
}

prune_releases() {
  local releases_dir="$1"
  local keep_releases="$2"
  local active_release="$3"
  local keep_non_active=$((keep_releases - 1))
  local retained=0
  local release_path
  local release_name

  # Keep the active release plus the newest non-active releases. This preserves
  # rollback choices while avoiding deletion of the release currently serving.
  { find "$releases_dir" -mindepth 1 -maxdepth 1 -type d -printf '%T@\t%p\n' 2>/dev/null || true; } |
  sort -rn |
  while IFS=$'\t' read -r _ release_path; do
    release_name="${release_path##*/}"
    [[ "$release_name" == "$active_release" ]] && continue

    if ((retained < keep_non_active)); then
      retained=$((retained + 1))
      continue
    fi

    rm -rf -- "$release_path"
  done
}

run_post_deploy() {
  local docroot="$1"
  local post_deploy_file="$2"

  [[ -n "$post_deploy_file" ]] || return 0
  [[ -f "$post_deploy_file" ]] || engine_die "post-deploy file does not exist: $post_deploy_file"

  (cd "$docroot" && bash -e "$post_deploy_file")
}

public_symlink_target() {
  local deployment_id="$1"
  local claim="$2"
  local parent="$claim"
  local prefix=""

  # Build a relative target from the claim's parent directory. Example:
  # wp-content/plugins/foo -> ../../.wpcloud-site-git-deploy/.../current/wp-content/plugins/foo
  if [[ "$parent" == */* ]]; then
    parent="${parent%/*}"
    while [[ -n "$parent" ]]; do
      prefix="../$prefix"
      if [[ "$parent" == */* ]]; then
        parent="${parent%/*}"
      else
        parent=""
      fi
    done
  fi

  printf '%s%s/deployments/%s/current/%s\n' "$prefix" "$DOCROOT_NAMESPACE" "$deployment_id" "$claim"
}

reconcile_new_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local claims_file="$3"
  local exchange_helper="$4"
  local exchanged_paths_file="$5"
  local claim
  local public_path
  local parent_dir
  local target
  local tmp_link

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    [[ -n "$claim" ]] || continue

    public_path="$docroot/$claim"
    parent_dir="${public_path%/*}"
    target="$(public_symlink_target "$deployment_id" "$claim")"
    tmp_link="$parent_dir/.${public_path##*/}.$DOCROOT_NAMESPACE_SUFFIX.$$"

    reject_foreign_deployment_ancestor_claim "$docroot" "$deployment_id" "$claim"
    mkdir -p -- "$parent_dir"
    reject_foreign_deployment_claim "$deployment_id" "$claim" "$public_path"
    reject_foreign_deployment_descendant_claim "$deployment_id" "$claim" "$public_path"
    rm -f -- "$tmp_link"
    ln -s "$target" "$tmp_link"

    if [[ ! -e "$public_path" && ! -L "$public_path" ]]; then
      mv -T -- "$tmp_link" "$public_path"
      continue
    fi

    [[ -x "$exchange_helper" ]] || engine_die "exchange helper is required to reclaim existing path: $claim"
    # Existing public paths may contain real files/directories. Swap in the
    # deploy symlink atomically, then defer deletion of the exchanged-away path
    # until current points at the new release.
    if ! "$exchange_helper" "$tmp_link" "$public_path"; then
      rm -f -- "$tmp_link"
      engine_die "exchange helper failed to reclaim path: $claim"
    fi
    printf '%s\n' "$tmp_link" >>"$exchanged_paths_file"
  done <"$claims_file"
}

cleanup_exchanged_paths() {
  local exchanged_paths_file="$1"
  local path

  # This file is durable on purpose. If cleanup failed after a prior atomic
  # exchange, the next deploy or rollback retries before changing claims again.
  [[ -f "$exchanged_paths_file" ]] || return 0
  while IFS= read -r path || [[ -n "$path" ]]; do
    [[ -n "$path" ]] || continue
    rm -rf -- "$path"
  done <"$exchanged_paths_file"
}

compute_removed_claims() {
  local old_claims_file="$1"
  local new_claims_file="$2"
  local removed_claims_file="$3"
  local old_sorted="$removed_claims_file.old.$$"
  local new_sorted="$removed_claims_file.new.$$"

  rm -f -- "$old_sorted" "$new_sorted"
  sort -u "$old_claims_file" >"$old_sorted"
  sort -u "$new_claims_file" >"$new_sorted"
  comm -23 "$old_sorted" "$new_sorted" >"$removed_claims_file"
  rm -f -- "$old_sorted" "$new_sorted"
}

deployment_owner_from_target() {
  local target="$1"

  if [[ "$target" =~ (^|/)$DOCROOT_NAMESPACE_REGEX/deployments/([^/]+)/current($|/) ]]; then
    printf '%s\n' "${BASH_REMATCH[2]}"
    return 0
  fi

  return 1
}

reject_foreign_deployment_claim() {
  local deployment_id="$1"
  local claim="$2"
  local public_path="$3"
  local target
  local owner

  [[ -L "$public_path" ]] || return 0

  target="$(readlink "$public_path")"
  if owner="$(deployment_owner_from_target "$target")" && [[ "$owner" != "$deployment_id" ]]; then
    engine_die "claim owned by another deployment: $claim"
  fi
}

reject_foreign_deployment_ancestor_claim() {
  local docroot="$1"
  local deployment_id="$2"
  local claim="$3"
  local ancestor="$docroot"
  local remainder="$claim"
  local component
  local target
  local owner

  # Layered deployments are allowed only when their public paths do not overlap.
  # A foreign ancestor symlink would route this claim into another deployment.
  while [[ "$remainder" == */* ]]; do
    component="${remainder%%/*}"
    remainder="${remainder#*/}"
    ancestor="$ancestor/$component"

    if [[ -L "$ancestor" ]]; then
      target="$(readlink "$ancestor")"
      if owner="$(deployment_owner_from_target "$target")" && [[ "$owner" != "$deployment_id" ]]; then
        engine_die "claim owned by another deployment: $claim"
      fi
    fi
  done
}

reject_foreign_deployment_descendant_claim() {
  local deployment_id="$1"
  local claim="$2"
  local public_path="$3"
  local link_path
  local target
  local owner
  local links_tmp

  [[ -d "$public_path" && ! -L "$public_path" ]] || return 0

  # Reclaiming a real directory is destructive to that exact path. Refuse when
  # it contains another deployment's symlink so layers cannot engulf each other.
  links_tmp="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-descendants.XXXXXX")" || engine_die "mktemp is required"
  find "$public_path" -mindepth 1 -type l -print0 >"$links_tmp" 2>/dev/null || true
  while IFS= read -r -d '' link_path; do
    target="$(readlink "$link_path")"
    if owner="$(deployment_owner_from_target "$target")" && [[ "$owner" != "$deployment_id" ]]; then
      engine_die "claim contains another deployment: $claim"
    fi
  done <"$links_tmp"
  rm -f -- "$links_tmp"
}

remove_exact_claim_symlink() {
  local docroot="$1"
  local deployment_id="$2"
  local claim="$3"
  local public_path="$docroot/$claim"
  local target
  local expected_target

  [[ -L "$public_path" ]] || return 0

  target="$(readlink "$public_path")"
  expected_target="$(public_symlink_target "$deployment_id" "$claim")"
  if [[ "$target" == "$expected_target" ]]; then
    rm -f -- "$public_path"
  fi
}

cleanup_removed_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local removed_claims_file="$3"
  local claim

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    [[ -n "$claim" ]] || continue
    remove_exact_claim_symlink "$docroot" "$deployment_id" "$claim"
  done <"$removed_claims_file"
}

claims_overlap() {
  local left="$1"
  local right="$2"

  [[ "$left" == "$right" || "$left" == "$right/"* || "$right" == "$left/"* ]]
}

cleanup_overlapping_removed_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local removed_claims_file="$3"
  local new_claims_file="$4"
  local removed_claim
  local new_claim

  while IFS= read -r removed_claim || [[ -n "$removed_claim" ]]; do
    [[ -n "$removed_claim" ]] || continue

    while IFS= read -r new_claim || [[ -n "$new_claim" ]]; do
      [[ -n "$new_claim" ]] || continue

      if claims_overlap "$removed_claim" "$new_claim"; then
        remove_exact_claim_symlink "$docroot" "$deployment_id" "$removed_claim"
        break
      fi
    done <"$new_claims_file"
  done <"$removed_claims_file"
}

discover_materialized_public_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local output_file="$3"
  local claims_tmp="$output_file.tmp.$$"
  local links_tmp="$output_file.links.$$"
  local link_path
  local claim
  local target
  local expected_target

  rm -f -- "$claims_tmp" "$links_tmp"
  : >"$claims_tmp"

  find "$docroot" -path "$docroot/$DOCROOT_NAMESPACE" -prune -o -type l -print0 >"$links_tmp" 2>/dev/null || true
  # shellcheck disable=SC2094
  while IFS= read -r -d '' link_path; do
    claim="${link_path#"$docroot"/}"

    if [[ "$claim" == *$'\n'* ]]; then
      rm -f -- "$claims_tmp" "$links_tmp"
      engine_die "unsupported newline in public symlink path"
    fi

    target="$(readlink "$link_path")"
    expected_target="$(public_symlink_target "$deployment_id" "$claim")"
    if [[ "$target" == "$expected_target" ]]; then
      printf '%s\n' "$claim"
    fi
  done <"$links_tmp" >"$claims_tmp"

  sort -u "$claims_tmp" >"$output_file"
  rm -f -- "$claims_tmp" "$links_tmp"
}

combine_claims() {
  local output_file="$1"
  shift
  local combined_tmp="$output_file.tmp.$$"

  rm -f -- "$combined_tmp"
  cat "$@" | sort -u >"$combined_tmp"
  mv "$combined_tmp" "$output_file"
}

normalize_public_path() {
  local value="$1"

  value="${value#./}"
  while [[ "$value" == */ ]]; do
    value="${value%/}"
  done

  if [[ "$value" == "." ]]; then
    value=""
  fi

  printf '%s' "$value"
}

discover_boundary_claims() {
  discover_docroot_paths \
    "$1" \
    "${WPCLOUD_SITE_GIT_DEPLOY_BOUNDARIES_FILE:-}" \
    "boundary" \
    "$2" \
    -type d \( -uid 0 -or -gid 0 \) -and -perm -1000
}

discover_protected_anchors() {
  local docroot="$1"
  local output_file="$2"
  discover_docroot_paths \
    "$docroot" \
    "${WPCLOUD_SITE_GIT_DEPLOY_PROTECTED_ANCHORS_FILE:-}" \
    "protected anchors" \
    "$output_file" \
    \( -uid 0 -or -gid 0 \) -and -not -writable
}

discover_docroot_paths() {
  local docroot="$1"
  local override_file="$2"
  local label="$3"
  local output_file="$4"
  shift 4
  local path
  local normalized

  if [[ -n "$override_file" ]]; then
    [[ -f "$override_file" ]] || engine_die "$label override file does not exist: $override_file"
    while IFS= read -r path || [[ -n "$path" ]]; do
      normalized="$(normalize_public_path "$path")"
      printf '%s\n' "$normalized"
    done <"$override_file"
  else
    { find "$docroot" "$@" 2>/dev/null || true; } |
    while IFS= read -r path; do
      if [[ "$path" == "$docroot" ]]; then
        normalized=""
      else
        normalized="$(normalize_public_path "${path#"$docroot"/}")"
      fi
      printf '%s\n' "$normalized"
    done
  fi | sort -u >"$output_file"
}

validate_claims_not_protected() {
  local claims_file="$1"
  local protected_anchors_file="$2"
  local pair
  local tmp_prefix
  local ancestor_pairs_file
  local ancestor_keys_file
  local claim_keys_file
  local protected_ancestor_pairs_file
  local protected_ancestor_keys_file
  local protected_keys_file
  local blocked_anchors_file
  local blocked_claim

  tmp_prefix="${claims_file}.protected.$$"
  ancestor_pairs_file="$tmp_prefix.ancestor-pairs"
  ancestor_keys_file="$tmp_prefix.ancestor-keys"
  claim_keys_file="$tmp_prefix.claim-keys"
  protected_ancestor_pairs_file="$tmp_prefix.protected-ancestor-pairs"
  protected_ancestor_keys_file="$tmp_prefix.protected-ancestor-keys"
  protected_keys_file="$tmp_prefix.protected-keys"
  blocked_anchors_file="$tmp_prefix.blocked-anchors"

  # A claim is unsafe if it equals, descends from, or contains a protected
  # anchor. Expand both sides to ancestor sets so the overlap check stays in
  # standard sorted-file operations instead of nested path-walking logic.
  expand_ancestor_pairs "$claims_file" >"$ancestor_pairs_file"

  cut -f1 "$ancestor_pairs_file" | sort -u >"$ancestor_keys_file"
  sort -u "$claims_file" >"$claim_keys_file"
  sort -u "$protected_anchors_file" >"$protected_keys_file"
  comm -12 "$protected_keys_file" "$ancestor_keys_file" >"$blocked_anchors_file"

  expand_ancestor_pairs "$protected_keys_file" >"$protected_ancestor_pairs_file"

  cut -f1 "$protected_ancestor_pairs_file" | sort -u >"$protected_ancestor_keys_file"
  comm -12 "$claim_keys_file" "$protected_ancestor_keys_file" >>"$blocked_anchors_file"
  sort -u "$blocked_anchors_file" -o "$blocked_anchors_file"

  if [[ -s "$blocked_anchors_file" ]]; then
    blocked_claim="$(
      while IFS= read -r pair || [[ -n "$pair" ]]; do
        if grep -Fxq -- "${pair%%$'\t'*}" "$blocked_anchors_file"; then
          printf '%s\n' "${pair#*$'\t'}"
          break
        fi
      done <"$ancestor_pairs_file"
    )"
    engine_die "protected path: $blocked_claim"
  fi
}

expand_ancestor_pairs() {
  local input_file="$1"
  local claim
  local ancestor

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    ancestor="$claim"
    while true; do
      printf '%s\t%s\n' "$ancestor" "$claim"
      [[ -z "$ancestor" ]] && break

      if [[ "$ancestor" == */* ]]; then
        ancestor="${ancestor%/*}"
      else
        ancestor=""
      fi
    done
  done <"$input_file"
}

claim_for_path() {
  local public_path="$1"
  local boundaries_file="$2"
  local best_boundary=""
  local boundary
  local remainder
  local next_segment

  # Sticky boundaries mark dynamic areas such as wp-content/plugins. Inside the
  # deepest boundary, deploy only the next child as the public claim so one
  # plugin/theme does not claim the whole writable parent directory.
  while IFS= read -r boundary || [[ -n "$boundary" ]]; do
    if [[ -z "$boundary" ]]; then
      continue
    fi

    if [[ "$public_path" == "$boundary/"* && ${#boundary} -gt ${#best_boundary} ]]; then
      best_boundary="$boundary"
    fi
  done <"$boundaries_file"

  if [[ -n "$best_boundary" ]]; then
    remainder="${public_path#"$best_boundary"/}"
    next_segment="${remainder%%/*}"
    printf '%s/%s\n' "$best_boundary" "$next_segment"
    return
  fi

  printf '%s\n' "${public_path%%/*}"
}

shared_path_for_public_path() {
  local public_path="$1"
  local shared_path

  for shared_path in "${DEFAULT_SHARED_PATHS[@]}"; do
    if [[ "$public_path" == "$shared_path" || "$public_path" == "$shared_path/"* ]]; then
      printf '%s\n' "$shared_path"
      return 0
    fi
  done
  return 1
}

compute_claims() {
  local release_tree="$1"
  local boundaries_file="$2"
  local output_file="$3"
  local reject_shared_paths="${4:-0}"
  local release_file
  local public_path
  local shared_path
  local claims_tmp="$output_file.tmp.$$"
  local sorted_tmp="$output_file.sorted.$$"
  local find_tmp="$output_file.find.$$"

  rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
  if [[ ! -d "$release_tree" ]]; then
    : >"$output_file"
    return 0
  fi

  find "$release_tree" \( -type f -or -type l \) -print0 >"$find_tmp"
  # shellcheck disable=SC2094
  while IFS= read -r -d '' release_file; do
    public_path="${release_file#"$release_tree"/}"

    if [[ "$public_path" == *$'\n'* ]]; then
      rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
      engine_die "unsupported newline in release path"
    fi

    case "$public_path" in
      .git|.git/*)
        continue
        ;;
      "$DOCROOT_NAMESPACE"|"$DOCROOT_NAMESPACE"/*)
        # Never claim the deployment namespace itself. If caller-controlled
        # excludes allow the deployment namespace into a release, claiming it would
        # swap releases, lock, and helper for a symlink into that same release.
        continue
        ;;
    esac
    if [[ "$reject_shared_paths" == "1" ]] && shared_path="$(shared_path_for_public_path "$public_path")"; then
      rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
      engine_die "shared path cannot be deployed: $shared_path"
    fi

    claim_for_path "$public_path" "$boundaries_file"
  done <"$find_tmp" >"$claims_tmp"

  sort -u "$claims_tmp" >"$sorted_tmp"
  mv "$sorted_tmp" "$output_file"
  rm -f -- "$claims_tmp" "$find_tmp"
}

prepare_claim_transition() {
  local docroot="$1"
  local deployment_id="$2"
  local base="$3"
  local target_release_dir="$4"
  local scratch_dir="$5"
  local boundaries_file="$scratch_dir/boundaries"
  local protected_anchors_file="$scratch_dir/protected_anchors"
  local old_release_claims_file="$scratch_dir/old_release_claims"
  local materialized_claims_file="$scratch_dir/materialized_claims"
  local old_claims_file="$scratch_dir/old_claims"
  local new_claims_file="$scratch_dir/new_claims"
  local removed_claims_file="$scratch_dir/removed_claims"
  local current_target=""

  discover_boundary_claims "$docroot" "$boundaries_file"
  discover_protected_anchors "$docroot" "$protected_anchors_file"

  if [[ -L "$base/current" ]]; then
    current_target="$(readlink "$base/current")"
    compute_claims "$base/$current_target" "$boundaries_file" "$old_release_claims_file"
  else
    : >"$old_release_claims_file"
  fi

  # The previous release tree is not the whole truth: public symlinks may have
  # survived manual repair or a failed cleanup. Include materialized symlinks so
  # removal/reclaim decisions reflect the actual docroot state.
  discover_materialized_public_claims "$docroot" "$deployment_id" "$materialized_claims_file"
  combine_claims "$old_claims_file" "$old_release_claims_file" "$materialized_claims_file"
  compute_claims "$target_release_dir" "$boundaries_file" "$new_claims_file" 1
  validate_claims_not_protected "$new_claims_file" "$protected_anchors_file"
  compute_removed_claims "$old_claims_file" "$new_claims_file" "$removed_claims_file"
}

apply_claim_transition() {
  local docroot="$1"
  local deployment_id="$2"
  local base="$3"
  local release_id="$4"
  local exchange_helper="$5"
  local scratch_dir="$6"
  local new_claims_file="$scratch_dir/new_claims"
  local removed_claims_file="$scratch_dir/removed_claims"
  local exchanged_paths_file="$base/exchanged_paths"

  : >"$exchanged_paths_file"
  # Parent/child claim granularity can change between releases. Remove exact
  # overlapping old symlinks before creating new claims so they cannot block
  # parent/child directory creation.
  cleanup_overlapping_removed_claims "$docroot" "$deployment_id" "$removed_claims_file" "$new_claims_file"
  reconcile_new_claims "$docroot" "$deployment_id" "$new_claims_file" "$exchange_helper" "$exchanged_paths_file"
  switch_current "$base" "$release_id"
  [[ "$(readlink "$base/current")" == "releases/$release_id" ]] || engine_die "current does not point to releases/$release_id"
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  # Non-overlapping removed claims are cleaned only after current points at the
  # new release, so public requests never see old symlinks pointing into a
  # not-yet-current tree.
  cleanup_removed_claims "$docroot" "$deployment_id" "$removed_claims_file"
  assert_claim_symlinks_under_docroot "$docroot" "$new_claims_file"
}

rollback_release() {
  local docroot="$1"
  local deployment_id="$2"
  local rollback_to="$3"
  local exchange_helper="$4"
  local maintenance_file="$5"

  local base
  local releases_dir
  local release_dir
  local lock_file
  local exchanged_paths_file
  local scratch_dir

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  releases_dir="$base/releases"
  release_dir="$releases_dir/$rollback_to"
  lock_file="$base/deploy.lock"
  exchanged_paths_file="$base/exchanged_paths"

  mkdir -p "$releases_dir"

  acquire_lock "$lock_file"

  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  [[ -d "$release_dir" ]] || engine_die "rollback release does not exist: $release_dir"
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  sweep_stale_scratch_dirs "$base"

  scratch_dir="$(create_scratch_dir "$base")"
  create_maintenance_file "$docroot" "$deployment_id" "$rollback_to" "$maintenance_file"
  prepare_claim_transition "$docroot" "$deployment_id" "$base" "$release_dir" "$scratch_dir"
  apply_claim_transition "$docroot" "$deployment_id" "$base" "$rollback_to" "$exchange_helper" "$scratch_dir"
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"

  echo "wpcloud-site-git-deploy __remote-deploy: current=releases/$rollback_to" >&2
}

cmd_remote_deploy() {
  local docroot=""
  local deployment_id=""
  local release_id=""
  local rollback_to=""
  local keep_releases=""
  local post_deploy_file=""
  local maintenance_file="$DEFAULT_MAINTENANCE_FILE"
  local exchange_helper=""
  local print_claims=0
  local assert_public_symlinks=0

  # Hidden internal/diagnostic command. The public deploy path calls this in a
  # subshell after rsyncing incoming content so engine exits cannot bypass the
  # outer cleanup paths.
  while (($#)); do
    case "$1" in
      --help|-h)
        engine_usage
        exit 0
        ;;
      --version)
        echo "$VERSION"
        exit 0
        ;;
      --docroot)
        (($# >= 2)) || engine_die "--docroot requires a value"
        docroot="$2"
        shift 2
        ;;
      --deployment-id)
        (($# >= 2)) || engine_die "--deployment-id requires a value"
        deployment_id="$2"
        shift 2
        ;;
      --release-id)
        (($# >= 2)) || engine_die "--release-id requires a value"
        release_id="$2"
        shift 2
        ;;
      --rollback-to)
        (($# >= 2)) || engine_die "--rollback-to requires a value"
        rollback_to="$2"
        shift 2
        ;;
      --keep-releases)
        (($# >= 2)) || engine_die "--keep-releases requires a value"
        keep_releases="$2"
        shift 2
        ;;
      --post-deploy-file)
        (($# >= 2)) || engine_die "--post-deploy-file requires a value"
        post_deploy_file="$2"
        shift 2
        ;;
      --maintenance-file)
        (($# >= 2)) || engine_die "--maintenance-file requires a value"
        maintenance_file="$2"
        shift 2
        ;;
      --exchange-helper)
        (($# >= 2)) || engine_die "--exchange-helper requires a value"
        exchange_helper="$2"
        shift 2
        ;;
      --print-claims)
        print_claims=1
        shift
        ;;
      --assert-public-symlinks)
        assert_public_symlinks=1
        shift
        ;;
      *)
        engine_die "unknown argument: $1"
        ;;
    esac
  done

  docroot="$(trim "$docroot")"
  deployment_id="$(trim "$deployment_id")"
  release_id="$(trim "$release_id")"
  rollback_to="$(trim "$rollback_to")"
  keep_releases="$(trim "$keep_releases")"
  post_deploy_file="$(trim "$post_deploy_file")"
  maintenance_file="$(trim "$maintenance_file")"
  exchange_helper="$(trim "$exchange_helper")"

  [[ -n "$docroot" ]] || engine_die "docroot is required"
  require_maintenance_file "$maintenance_file" engine_die

  if ((assert_public_symlinks)); then
    trap cleanup_run_scratch EXIT
    require_remote_capabilities
    assert_public_symlinks_under_docroot "$docroot"
    return
  fi

  engine_require_id "deployment-id" "$deployment_id"
  if [[ -z "$exchange_helper" ]]; then
    exchange_helper="$(docroot_deployment_base "$docroot" "$deployment_id")/exchange-rename"
  fi

  ENGINE_MAINTENANCE_DOCROOT="$docroot"
  ENGINE_MAINTENANCE_DEPLOYMENT_ID="$deployment_id"
  ENGINE_MAINTENANCE_FILE="$maintenance_file"
  trap cleanup_engine_exit EXIT
  require_remote_capabilities

  if [[ -n "$rollback_to" ]]; then
    [[ -z "$release_id" ]] || engine_die "--release-id cannot be used with --rollback-to"
    if [[ -n "$keep_releases" ]]; then
      if [[ ! "$keep_releases" =~ ^[0-9]+$ ]] || ((10#$keep_releases < 1)); then
        engine_die "keep-releases must be a positive integer"
      fi
    fi
    [[ -z "$post_deploy_file" ]] || engine_die "--post-deploy-file cannot be used with --rollback-to"
    ((print_claims == 0)) || engine_die "--print-claims cannot be used with --rollback-to"
    engine_require_id "rollback-to" "$rollback_to"
    rollback_release "$docroot" "$deployment_id" "$rollback_to" "$exchange_helper" "$maintenance_file"
    return
  fi

  engine_require_id "release-id" "$release_id"
  if [[ ! "$keep_releases" =~ ^[0-9]+$ ]] || ((10#$keep_releases < 1)); then
    engine_die "keep-releases must be a positive integer"
  fi

  local base
  local incoming_dir
  local releases_dir
  local incoming_release
  local release_dir
  local lock_file
  local exchanged_paths_file
  local scratch_dir
  local boundaries_file
  local new_claims_file

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  incoming_dir="$base/incoming"
  releases_dir="$base/releases"
  incoming_release="$incoming_dir/$release_id"
  release_dir="$releases_dir/$release_id"
  lock_file="$base/deploy.lock"
  exchanged_paths_file="$base/exchanged_paths"

  mkdir -p "$incoming_dir" "$releases_dir"

  acquire_lock "$lock_file"

  [[ -d "$incoming_release" ]] || engine_die "incoming release does not exist: $incoming_release"
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  sweep_stale_scratch_dirs "$base"
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"

  scratch_dir="$(create_scratch_dir "$base")"
  boundaries_file="$scratch_dir/boundaries"
  new_claims_file="$scratch_dir/new_claims"
  discover_boundary_claims "$docroot" "$boundaries_file"

  if ((print_claims)); then
    compute_claims "$incoming_release" "$boundaries_file" "$new_claims_file" 1
    cat "$new_claims_file"
    exit 0
  fi

  [[ ! -e "$release_dir" ]] || engine_die "release already exists: $release_dir"

  create_maintenance_file "$docroot" "$deployment_id" "$release_id" "$maintenance_file"
  prepare_claim_transition "$docroot" "$deployment_id" "$base" "$incoming_release" "$scratch_dir"
  mv "$incoming_release" "$release_dir"
  # Uploaded directory mtimes reflect upload time. Refresh the promoted release
  # mtime so keep-releases pruning keeps the most recently promoted releases.
  touch "$release_dir"
  apply_claim_transition "$docroot" "$deployment_id" "$base" "$release_id" "$exchange_helper" "$scratch_dir"
  if ! run_post_deploy "$docroot" "$post_deploy_file"; then
    cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
    engine_die "post-deploy failed: $post_deploy_file"
  fi
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  prune_releases "$releases_dir" "$keep_releases" "$release_id"

  echo "wpcloud-site-git-deploy __remote-deploy: current=releases/$release_id" >&2
}

# Final command dispatcher

main() {
  local command="${1:-}"
  shift || true

  case "$command" in
    init)
      cmd_init "$@"
      ;;
    config)
      cmd_config "$@"
      ;;
    deploy)
      cmd_deploy "$@"
      ;;
    update)
      cmd_update "$@"
      ;;
    rollback)
      cmd_rollback "$@"
      ;;
    releases)
      cmd_releases "$@"
      ;;
    branches)
      cmd_branches "$@"
      ;;
    tags)
      cmd_tags "$@"
      ;;
    commits)
      cmd_commits "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    auth)
      cmd_auth "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    __remote-deploy)
      cmd_remote_deploy "$@"
      ;;
    --help|-h|"")
      usage
      ;;
    --version)
      echo "$VERSION"
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
