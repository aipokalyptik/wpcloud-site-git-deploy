#!/usr/bin/env bash
set -euo pipefail

# Global State And Constants
#
# Version, default settings, filesystem locations, and shared mutable parser
# state used by the single-file CLI.

readonly VERSION="1.1.5"
# Default number of promoted docroot releases retained for rollback.
readonly DEFAULT_KEEP_RELEASES="3"
# Default tool-owned WordPress maintenance marker created during promotion.
readonly DEFAULT_MAINTENANCE_FILE=".maintenance"
# Web-visible deployment namespace under the docroot.
readonly DOCROOT_NAMESPACE=".wpcloud-site-git-deploy"
# Strip the leading dot once so temporary filenames can reuse the namespace
# without creating hidden path components inside operator-facing directories.
readonly DOCROOT_NAMESPACE_SUFFIX="${DOCROOT_NAMESPACE#.}"
readonly DOCROOT_NAMESPACE_REGEX="\\.wpcloud-site-git-deploy"
# WordPress-managed runtime paths that should never be claimed by a Git deploy.
readonly -a REJECTED_SHARED_PATHS=(wp-content/cache wp-content/upgrade .maintenance)
# Persistent media containers may hold deploy-managed regular-file leaf symlinks,
# but the containers themselves remain owned by WordPress.
readonly -a SHARED_CONTAINER_PATHS=(wp-content/uploads wp-content/blogs.dir)
# Location of this checked-out or installed CLI. Source installs use REPO_ROOT
# to find the bundled helper; managed installs primarily use STATE_DIR instead.
SCRIPT_DIR="$(
cd "$(dirname "${BASH_SOURCE[0]}")"
pwd
)"
REPO_ROOT="$(
cd "$SCRIPT_DIR/.."
pwd
)"
# Tool-owned runtime state. Override with WPCLOUD_SITE_GIT_DEPLOY_HOME in tests
# or nonstandard installs; production defaults to the site SSH user's HOME.
STATE_DIR="${WPCLOUD_SITE_GIT_DEPLOY_HOME:-$HOME/.wpcloud-site-git-deploy}"
# Per-deployment config directories, repo caches, transient worktrees, installed
# helper binaries, and deploy keys are intentionally kept outside the docroot.
DEPLOYMENTS_DIR="$STATE_DIR/deployments"
REPOS_DIR="$STATE_DIR/repos"
TMP_DIR="$STATE_DIR/tmp"
BIN_DIR="$STATE_DIR/bin"
KEYS_DIR="$STATE_DIR/keys"
# Fallback helper path when running directly from a source checkout.
HELPER_SOURCE="$REPO_ROOT/helpers/bin/linux-amd64/exchange-rename"

# Shared parser state for the currently executing command. args_begin_with_die
# resets these variables so cmd_* handlers can read named options without
# carrying a bespoke while/case parser in every function.
ARGS_COMMAND=""
ARGS_DIE_FUNC="die"
ARGS=()
ARGS_FLAGS=()
ARGS_VALUES=()
AUTH_RESOLVED_KEY_PATH=""
AUTH_RESOLVED_PUBLIC_KEY=""

# Common CLI Helpers
#
# Small, command-agnostic utilities for usage output, fatal errors, identifier
# validation, and shared predicates.

usage() {
  cat <<-'USAGE'
	wpcloud-site-git-deploy deploys a Git repository into a WP Cloud or Pressable docroot from the site SSH user.

	Usage:
	  wpcloud-site-git-deploy init <name> --repo URL --docroot /srv/htdocs --deployment-id ID --default-ref main [--keep-releases N] [--deploy-root PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy config <name> [--deploy-root PATH | --clear-deploy-root | --post-deploy PATH | --clear-post-deploy | --maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --branch BRANCH [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --tag TAG [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy deploy <name> --commit SHA [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy update <name> [--force] [--post-deploy PATH] [--maintenance-file PATH|none]
	  wpcloud-site-git-deploy rollback <name> [--to RELEASE_ID]
	  wpcloud-site-git-deploy releases <name>
	  wpcloud-site-git-deploy branches <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy tags <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy commits <name> [--fetch] [--limit N]
	  wpcloud-site-git-deploy status <name>
	  wpcloud-site-git-deploy auth <name> [--force-new-key] [--verify] [--use-key PATH | --import-key PATH | --remove [--purge-key]]
	  wpcloud-site-git-deploy doctor <name> [--offline]
	  wpcloud-site-git-deploy --help
	  wpcloud-site-git-deploy --version
	USAGE
}

die() {
  echo "wpcloud-site-git-deploy: $*" >&2
  exit 64
}

require_name() {
  if [[ ! "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]]; then
    die "deployment name must contain only letters, numbers, dot, underscore, or dash"
  fi
}

is_positive_int() {
  # 10# forces base-10 arithmetic so values with a leading zero are not treated
  # as octal by Bash arithmetic expansion.
  if [[ "${1:-}" =~ ^[0-9]+$ ]]; then
    if ((10#$1 >= 1)); then
      return 0
    fi
  fi
  return 1
}

# Command Argument Helpers
#
# The helpers below register the option names that a command reads, then
# args_finish validates the original argv stream against those registered flag
# and value-option sets. That keeps the readability benefit of named accessors
# while preserving strict parser behavior: unknown options fail, stray
# positional arguments fail, and missing values point at the exact option that
# caused the error.

args_begin_with_die() {
  ARGS_DIE_FUNC="$1"
  ARGS_COMMAND="$2"
  shift 2
  ARGS=("$@")
  ARGS_FLAGS=()
  ARGS_VALUES=()
}

args_is_registered_flag() {
  local option="$1"
  local registered

  for registered in "${ARGS_FLAGS[@]}"; do
    if [[ "$option" == "$registered" ]]; then
      return 0
    fi
  done
  return 1
}

args_is_registered_value() {
  local option="$1"
  local registered

  for registered in "${ARGS_VALUES[@]}"; do
    if [[ "$option" == "$registered" ]]; then
      return 0
    fi
  done
  return 1
}

args_finish() {
  local index=0
  local arg
  local option
  local unknown_message

  while ((index < ${#ARGS[@]})); do
    arg="${ARGS[$index]}"
    # For --option=value syntax, the option name is the part before the first
    # equals sign; space-separated --option value arguments remain unchanged.
    option="${arg%%=*}"

    if args_is_registered_flag "$arg"; then
      index=$((index + 1))
      continue
    fi
    if [[ "$arg" == *=* ]]; then
      if [[ "$arg" == --* ]]; then
        if args_is_registered_value "$option"; then
          index=$((index + 1))
          continue
        fi
      fi
    fi
    if args_is_registered_value "$arg"; then
      if ((index + 1 >= ${#ARGS[@]})); then
        "$ARGS_DIE_FUNC" "$arg requires a value"
      fi
      if [[ "${ARGS[$((index + 1))]}" == --* ]]; then
        "$ARGS_DIE_FUNC" "$arg requires a value"
      fi
      index=$((index + 2))
      continue
    fi

    if [[ "$ARGS_COMMAND" == "argument" ]]; then
      unknown_message="unknown argument: $option"
    else
      unknown_message="unknown ${ARGS_COMMAND} argument: $option"
    fi
    "$ARGS_DIE_FUNC" "$unknown_message"
  done
}

# Returns true when a flag is present. Repeated flags are allowed and collapse
# naturally to true, matching the old hand-written parsers.
arg_has() {
  local needle="$1"
  local index

  ARGS_FLAGS+=("$needle")
  # Iterate by index so later parser helpers can use the same argv snapshot
  # without consuming positional parameters.
  for index in "${!ARGS[@]}"; do
    if [[ "${ARGS[$index]}" == "$needle" ]]; then
      return 0
    fi
  done
  return 1
}

arg_read_value_count() {
  local dest="$1"
  local count_dest="$2"
  local key="$3"
  local validator="${4:-}"
  local index
  local arg
  local arg_parsed_value
  local value_index
  local arg_parsed_count=0

  ARGS_VALUES+=("$key")
  for index in "${!ARGS[@]}"; do
    arg="${ARGS[$index]}"
    if [[ "$arg" == "$key" ]]; then
      value_index=$((index + 1))
      if ((value_index >= ${#ARGS[@]})); then
        "$ARGS_DIE_FUNC" "$key requires a value"
      fi
      arg_parsed_value="${ARGS[$value_index]}"
      if [[ "$arg_parsed_value" == --* ]]; then
        "$ARGS_DIE_FUNC" "$key requires a value"
      fi
      # printf -v assigns without command substitution, which avoids losing
      # state in a subshell while still preserving exact string contents.
      printf -v "$dest" '%s' "$arg_parsed_value"
      arg_parsed_count=$((arg_parsed_count + 1))
    elif [[ "$arg" == "$key="* ]]; then
      # For --option=value, keep everything after the first equals sign as the
      # caller's value. Additional equals signs are part of the value.
      arg_parsed_value="${arg#*=}"
      if [[ -z "$arg_parsed_value" ]]; then
        if [[ -z "$validator" ]]; then
          "$ARGS_DIE_FUNC" "$key requires a value"
        fi
      fi
      printf -v "$dest" '%s' "$arg_parsed_value"
      arg_parsed_count=$((arg_parsed_count + 1))
    fi
  done

  if ((arg_parsed_count > 0)); then
    if [[ -n "$validator" ]]; then
      # Indirect expansion reads the variable named by $dest so validators see
      # the value just assigned with printf -v.
      "$validator" "${!dest}"
    fi
  fi
  printf -v "$count_dest" '%s' "$arg_parsed_count"
}

# Assigns a value option to a named variable. This avoids command-substitution
# subshells when the command needs to keep the value for later logic.
arg_set() {
  local dest="$1"
  local key="$2"
  local validator="${3:-}"
  local parsed_count

  arg_read_value_count "$dest" parsed_count "$key" "$validator"
}

# Reads exactly one deploy ref selector, such as --branch, --tag, or --commit,
# and rejects both mixed selectors and repeated selectors.
arg_ref_choice() {
  local mode_dest="$1"
  local value_dest="$2"
  local found=0
  local option_name
  local mode_name
  local parsed_value
  local parsed_count

  shift 2
  printf -v "$mode_dest" ''
  printf -v "$value_dest" ''

  while (($#)); do
    option_name="$1"
    mode_name="$2"
    shift 2

    parsed_value=""
    arg_read_value_count parsed_value parsed_count "$option_name"
    if ((parsed_count > 0)); then
      if ((found != 0)); then
        "$ARGS_DIE_FUNC" "choose only one ref"
      fi
      if ((parsed_count != 1)); then
        "$ARGS_DIE_FUNC" "choose only one ref"
      fi
      printf -v "$mode_dest" '%s' "$mode_name"
      printf -v "$value_dest" '%s' "$parsed_value"
      found=$((found + parsed_count))
    fi
  done
}

# Handles commands such as config where exactly one option represents the
# action. Value actions can validate immediately; flag actions use "-" as the
# validator marker.
arg_one_action() {
  local action_dest="$1"
  local value_dest="$2"
  local option_name
  local action_name
  local validator
  local parsed_value
  local parsed_count
  local action_count=0

  shift 2
  printf -v "$action_dest" ''
  printf -v "$value_dest" ''

  while (($#)); do
    option_name="$1"
    action_name="$2"
    validator="$3"
    shift 3

    if [[ "$validator" == "-" ]]; then
      if arg_has "$option_name"; then
        action_count=$((action_count + 1))
        printf -v "$action_dest" '%s' "$action_name"
        printf -v "$value_dest" ''
      fi
    else
      parsed_value=""
      arg_read_value_count parsed_value parsed_count "$option_name" "$validator"
      if ((parsed_count > 0)); then
        action_count=$((action_count + 1))
        printf -v "$action_dest" '%s' "$action_name"
        printf -v "$value_dest" '%s' "$parsed_value"
      fi
    fi
  done

  if ((action_count <= 0)); then
    "$ARGS_DIE_FUNC" "config requires --deploy-root, --clear-deploy-root, --post-deploy, --clear-post-deploy, or --maintenance-file"
  fi
  if ((action_count != 1)); then
    "$ARGS_DIE_FUNC" "choose only one config option"
  fi
}

# Deployment Config And State
#
# Read and write the one-value-per-file deployment configuration, validate
# configurable paths, and create the tool-owned state directories.

config_dir() {
  local name="$1"
  printf '%s/%s\n' "$DEPLOYMENTS_DIR" "$name"
}

config_value_path() {
  local name="$1"
  local key="$2"

  printf '%s/cfg-%s\n' "$(config_dir "$name")" "$key"
}

read_config_value() {
  local name="$1"
  local key="$2"
  local default="${3:-}"
  local path

  path="$(config_value_path "$name" "$key")"
  if [[ -f "$path" ]]; then
    cat "$path"
  else
    printf '%s\n' "$default"
  fi
}

read_required_config_value() {
  local name="$1"
  local key="$2"
  local value

  value="$(read_config_value "$name" "$key")"
  if [[ -z "$value" ]]; then
    die "deployment config is missing required option: $key"
  fi
  printf '%s\n' "$value"
}

write_deployment_config_value() {
  local name="$1"
  local key="$2"
  local value="$3"
  local dir
  local path
  local tmp_path

  if [[ "$value" == *$'\n'* ]]; then
    die "deployment config value must not contain newlines: $key"
  fi
  dir="$(config_dir "$name")"
  path="$(config_value_path "$name" "$key")"
  tmp_path="$path.tmp.$$"
  mkdir -p "$dir"
  chmod 700 "$dir"
  printf '%s\n' "$value" >"$tmp_path"
  chmod 600 "$tmp_path"
  mv -f "$tmp_path" "$path"
}

remove_deployment_config_value() {
  local name="$1"
  local key="$2"

  rm -f -- "$(config_value_path "$name" "$key")"
}

load_config() {
  local name="$1"
  local dir

  require_name "$name"
  dir="$(config_dir "$name")"
  if [[ ! -d "$dir" ]]; then
    die "deployment is not initialized: $name"
  fi

  repo_url="$(read_required_config_value "$name" repo_url)"
  docroot="$(read_required_config_value "$name" docroot)"
  deployment_id="$(read_required_config_value "$name" deployment_id)"
  default_ref="$(read_required_config_value "$name" default_ref)"
  keep_releases="$(read_required_config_value "$name" keep_releases)"
  ssh_key_path="$(read_config_value "$name" ssh_key_path)"
  deploy_root="$(read_config_value "$name" deploy_root)"
  post_deploy="$(read_config_value "$name" post_deploy)"
  maintenance_file="$(read_config_value "$name" maintenance_file "$DEFAULT_MAINTENANCE_FILE")"
}

ensure_state_dirs() {
  mkdir -p "$DEPLOYMENTS_DIR" "$REPOS_DIR" "$TMP_DIR" "$BIN_DIR" "$KEYS_DIR"
}

write_config() {
  local name="$1"

  write_deployment_config_value "$name" repo_url "$repo_url"
  write_deployment_config_value "$name" docroot "$docroot"
  write_deployment_config_value "$name" deployment_id "$deployment_id"
  write_deployment_config_value "$name" default_ref "$default_ref"
  write_deployment_config_value "$name" keep_releases "$keep_releases"

  if [[ -n "${deploy_root:-}" ]]; then
    write_deployment_config_value "$name" deploy_root "$deploy_root"
  else
    remove_deployment_config_value "$name" deploy_root
  fi

  if [[ -n "${post_deploy:-}" ]]; then
    write_deployment_config_value "$name" post_deploy "$post_deploy"
  else
    remove_deployment_config_value "$name" post_deploy
  fi

  if [[ "${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}" != "$DEFAULT_MAINTENANCE_FILE" ]]; then
    write_deployment_config_value "$name" maintenance_file "$maintenance_file"
  else
    remove_deployment_config_value "$name" maintenance_file
  fi

  if [[ -n "${ssh_key_path:-}" ]]; then
    write_deployment_config_value "$name" ssh_key_path "$ssh_key_path"
  else
    remove_deployment_config_value "$name" ssh_key_path
  fi
}

require_post_deploy_path() {
  local value="$1"

  if [[ -z "$value" ]]; then
    die "post-deploy path must not be empty"
  fi
  if [[ "$value" == *$'\n'* ]]; then
    die "post-deploy path must not contain newlines"
  fi
}

require_maintenance_file() {
  local value="$1"
  local die_fn="${2:-die}"
  local component
  local rest

  if [[ "$value" == "none" ]]; then
    return 0
  fi

  if [[ -z "$value" ]]; then
    "$die_fn" "maintenance-file must be a safe relative path or none"
  fi
  if [[ "$value" == /* ]]; then
    "$die_fn" "maintenance-file must be a safe relative path or none"
  fi
  if [[ "$value" == *$'\n'* ]]; then
    "$die_fn" "maintenance-file must be a safe relative path or none"
  fi
  if [[ "$value" == */ ]]; then
    "$die_fn" "maintenance-file must be a safe relative path or none"
  fi
  if [[ "$value" == *//* ]]; then
    "$die_fn" "maintenance-file must be a safe relative path or none"
  fi

  rest="$value"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" == */* ]]; then
      # Take the path component before the first slash, then remove that
      # component and slash so the next loop iteration can inspect the rest.
      component="${rest%%/*}"
      rest="${rest#*/}"
    else
      component="$rest"
      rest=""
    fi
    if [[ "$component" == "." ]]; then
      "$die_fn" "maintenance-file must be a safe relative path or none"
    fi
    if [[ "$component" == ".." ]]; then
      "$die_fn" "maintenance-file must be a safe relative path or none"
    fi
    if [[ -z "$component" ]]; then
      "$die_fn" "maintenance-file must be a safe relative path or none"
    fi
  done
}

require_deploy_root() {
  local value="$1"
  local component
  local rest

  # Empty would be ambiguous with the default repository root. Callers clear
  # deploy_root explicitly instead of storing an empty configured path.
  if [[ -z "$value" ]]; then
    die "deploy-root must be a safe relative path"
  fi
  # Absolute paths would let deploy-root escape the checked-out repository.
  if [[ "$value" == /* ]]; then
    die "deploy-root must be a safe relative path"
  fi
  # Newlines would corrupt the one-value-per-file config and metadata format.
  if [[ "$value" == *$'\n'* ]]; then
    die "deploy-root must be a safe relative path"
  fi
  # A trailing slash creates an empty final component and makes equivalent
  # paths serialize differently.
  if [[ "$value" == */ ]]; then
    die "deploy-root must be a safe relative path"
  fi
  # Repeated slashes create empty interior components and ambiguous spelling.
  if [[ "$value" == *//* ]]; then
    die "deploy-root must be a safe relative path"
  fi

  rest="$value"
  while [[ -n "$rest" ]]; do
    if [[ "$rest" == */* ]]; then
      # Take the next slash-separated path component and leave the unvalidated
      # suffix in rest for the following loop iteration.
      component="${rest%%/*}"
      rest="${rest#*/}"
    else
      component="$rest"
      rest=""
    fi
    # Reject empty, current-directory, and parent-directory components so the
    # deploy source is always a normal subdirectory inside the worktree.
    if [[ -z "$component" ]]; then
      die "deploy-root must be a safe relative path"
    fi
    if [[ "$component" == "." ]]; then
      die "deploy-root must be a safe relative path"
    fi
    if [[ "$component" == ".." ]]; then
      die "deploy-root must be a safe relative path"
    fi
  done
}

# Runtime, Git, And Repository Helpers
#
# Runtime capability helpers, exchange-rename discovery, Git authentication
# wrappers, exclude generation, repository cache fetching, and worktree prep.

git_ssh_command() {
  local key_path="${ssh_key_path:-}"
  local command
  local quoted_key_path

  if [[ -z "$key_path" ]]; then
    return 1
  fi

  # -i pins Git to the deployment-specific private key from config.
  # %q produces a shell-escaped path because GIT_SSH_COMMAND is parsed by ssh's
  # shell command invocation rather than passed as an argv array.
  printf -v quoted_key_path '%q' "$key_path"
  command="ssh -i $quoted_key_path"
  # IdentitiesOnly prevents ssh-agent or default keys from changing which
  # repository identity Git presents.
  command+=" -o IdentitiesOnly=yes"
  # BatchMode makes deploy/update fail instead of hanging on password or
  # passphrase prompts, which keeps unattended cron/API-triggered runs safe.
  command+=" -o BatchMode=yes"
  # accept-new preserves first-contact ergonomics while refusing changed host
  # keys after the first trust-on-first-use connection.
  command+=" -o StrictHostKeyChecking=accept-new"
  printf '%s\n' "$command"
}

git_with_auth() {
  local ssh_command

  if ssh_command="$(git_ssh_command)"; then
    GIT_SSH_COMMAND="$ssh_command" git "$@"
  else
    git "$@"
  fi
}

git_lfs_with_auth() {
  local ssh_command

  if ssh_command="$(git_ssh_command)"; then
    GIT_SSH_COMMAND="$ssh_command" git-lfs "$@"
  else
    git-lfs "$@"
  fi
}

mv_exchange_available() {
  local probe_dir
  local left
  local right
  local result=1

  if ! probe_dir="$(mktemp -d "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-mv-exchange.XXXXXX")"; then
    return 1
  fi
  left="$probe_dir/left"
  right="$probe_dir/right"
  printf 'left\n' >"$left"
  printf 'right\n' >"$right"
  if mv --exchange -- "$left" "$right" 2>/dev/null; then
    if [[ "$(cat "$left")" == "right" ]]; then
      if [[ "$(cat "$right")" == "left" ]]; then
        result=0
      fi
    fi
  fi
  rm -rf -- "$probe_dir"
  return "$result"
}

ensure_helper() {
  local helper="$BIN_DIR/exchange-rename"
  local path_helper

  if mv_exchange_available; then
    return 0
  fi

  if [[ -x "$helper" ]]; then
    printf '%s\n' "$helper"
    return 0
  fi

  if path_helper="$(command -v exchange-rename 2>/dev/null)"; then
    if [[ -x "$path_helper" ]]; then
      printf '%s\n' "$path_helper"
      return 0
    fi
  fi

  if [[ "$(uname -s)" != "Linux" ]]; then
    die "exchange helper installation requires Linux; run on the site host, Linux CI, or a Linux container/VM"
  fi

  if [[ ! -f "$HELPER_SOURCE" ]]; then
    die "exchange helper source binary not found: $HELPER_SOURCE"
  fi
  cp "$HELPER_SOURCE" "$helper"
  chmod 755 "$helper"
  printf '%s\n' "$helper"
}

default_exclude_file() {
  local output="$1"

  # Defaults block common repository and credential material. Users can still
  # deploy dotfiles such as .htaccess and .well-known because those are not in
  # this list; .gitignore is excluded because it is repo bookkeeping, not site
  # content, in this deploy model.
  {
    printf '%s\n' '.git'
    printf '%s\n' '.git/'
    printf '%s\n' '.gitignore'
    printf '%s\n' '.gitattributes'
    printf '%s\n' '.gitmodules'
    printf '%s\n' '.github/'
    printf '%s\n' '.svn/'
    printf '%s\n' '.hg/'
    printf '%s\n' '.bzr/'
    printf '%s\n' '.aws/'
    printf '%s\n' '.ssh/'
    printf '%s\n' '.env'
    printf '%s\n' '.env.*'
    printf '%s\n' '.npmrc'
    printf '%s\n' '.pypirc'
    printf '%s\n' '.netrc'
    printf '%s\n' '.DS_Store'
  } >"$output"
}

repo_dir_for() {
  local name="$1"
  printf '%s/%s\n' "$REPOS_DIR" "$name"
}

ensure_repo_cache() {
  local name="$1"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  if [[ -d "$repo_dir/.git" ]]; then
    git -C "$repo_dir" remote set-url origin "$repo_url"
  else
    rm -rf "$repo_dir"
    git_with_auth clone "$repo_url" "$repo_dir"
  fi
}

fetch_repo() {
  local name="$1"

  ensure_repo_cache "$name"
  git_with_auth -C "$(repo_dir_for "$name")" fetch --tags --prune origin
  git -C "$(repo_dir_for "$name")" gc --auto
}

resolve_ref() {
  local name="$1"
  local mode="$2"
  local value="$3"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  case "$mode" in
    branch)
      git -C "$repo_dir" rev-parse "refs/remotes/origin/$value^{commit}"
      ;;
    tag)
      git -C "$repo_dir" rev-parse "refs/tags/$value^{commit}"
      ;;
    commit)
      git -C "$repo_dir" rev-parse "$value^{commit}"
      ;;
    *)
      die "unknown ref mode: $mode"
      ;;
  esac
}

prepare_git_features() {
  local worktree="$1"
  local path
  local attr
  local uses_lfs=0
  local files_list="$TMP_DIR/git-files.$$.list"
  local attrs_list="$TMP_DIR/git-attrs.$$.list"
  local lfs_paths_list="$TMP_DIR/git-lfs-paths.$$.list"
  local lfs_pointer_paths="$TMP_DIR/git-lfs-pointers.$$.list"

  # Hydrate repository features that Git checkouts may leave incomplete for a
  # deployable filesystem: submodules first, then Git LFS objects.
  if [[ -f "$worktree/.gitmodules" ]]; then
    git_with_auth -C "$worktree" submodule update --init --recursive >&2
    if git -C "$worktree" submodule status --recursive | grep -Eq '^-'; then
      die "one or more submodules are uninitialized"
    fi
  fi

  # The deploy source is the checked-out filesystem, but LFS pointer files are
  # valid text files from Git's perspective. Detect LFS attributes and pull real
  # objects before copying into the docroot release tree.
  git -C "$worktree" ls-files -z >"$files_list"
  git -C "$worktree" check-attr filter --stdin -z <"$files_list" >"$attrs_list"
  printf '%s' '' >"$lfs_paths_list"
  # git check-attr -z returns triples of NUL-delimited fields:
  # path, attribute name, and attribute value. Read each field separately so the
  # loop describes that record shape instead of hiding it in a compact condition.
  while true; do
    if ! IFS= read -r -d '' path; then
      break
    fi
    if ! IFS= read -r -d '' _; then
      break
    fi
    if ! IFS= read -r -d '' attr; then
      break
    fi
    if [[ "$attr" == "lfs" ]]; then
      uses_lfs=1
      printf '%s\0' "$path" >>"$lfs_paths_list"
    fi
  done <"$attrs_list"
  rm -f "$files_list" "$attrs_list"

  if ((uses_lfs)); then
    if ! command -v git-lfs >/dev/null 2>&1; then
      die "git-lfs is required for repositories using Git LFS"
    fi
    (
      cd "$worktree"
      git_lfs_with_auth install --local
    ) >&2
    (
      cd "$worktree"
      git_lfs_with_auth pull
    ) >&2
    printf '%s' '' >"$lfs_pointer_paths"
    # lfs_paths_list is NUL-delimited because Git paths may contain whitespace.
    while IFS= read -r -d '' path; do
      if grep -Il '^version https://git-lfs.github.com/spec/v1$' -- "$worktree/$path" >/dev/null 2>&1; then
        printf '%s\n' "$path" >>"$lfs_pointer_paths"
      fi
    done <"$lfs_paths_list"
    if [[ -s "$lfs_pointer_paths" ]]; then
      die "Git LFS pointer files remain after git lfs pull"
    fi
    rm -f "$lfs_pointer_paths"
  fi
  rm -f "$lfs_paths_list"
}

# Deploy Orchestration And Release Metadata
#
# Docroot deployment namespace layout, release id generation, incoming release
# creation, metadata value files, no-op checks, promotion calls, cleanup, and
# rollback candidate selection.

docroot_deployment_base() {
  local root="$1"
  local id="$2"

  printf '%s/%s/deployments/%s\n' "$root" "$DOCROOT_NAMESPACE" "$id"
}

incoming_dir_for() {
  local base="$1"

  printf '%s/incoming\n' "$base"
}

incoming_release_dir_for() {
  local base="$1"
  local release_id="$2"

  printf '%s/%s\n' "$(incoming_dir_for "$base")" "$release_id"
}

releases_dir_for() {
  local base="$1"

  printf '%s/releases\n' "$base"
}

release_dir_for() {
  local base="$1"
  local release_id="$2"

  printf '%s/%s\n' "$(releases_dir_for "$base")" "$release_id"
}

metadata_dir_for() {
  local base="$1"

  printf '%s/metadata\n' "$base"
}

release_metadata_dir_for() {
  local base="$1"
  local release_id="$2"

  printf '%s/%s\n' "$(metadata_dir_for "$base")" "$release_id"
}

current_path_for() {
  local base="$1"

  printf '%s/current\n' "$base"
}

current_target_for() {
  local release_id="$1"

  printf 'releases/%s\n' "$release_id"
}

lock_path_for() {
  local base="$1"

  printf '%s/deploy.lock\n' "$base"
}

exchanged_paths_file_for() {
  local base="$1"

  printf '%s/exchanged_paths\n' "$base"
}

make_release_id() {
  local commit="$1"
  local random_hex

  # A release id names a deployment instance, not just Git content. The same
  # commit can be deployed more than once after rollback, config/deploy-root
  # changes, or a failed partial run, so a pure commit SHA would collide with
  # existing release and metadata paths. Keep the commit prefix for humans and
  # add a small random suffix for same-second redeploy uniqueness.
  random_hex="$(od -An -N2 -tx1 /dev/urandom | tr -d ' \n')"
  date -u "+%Y%m%d%H%M%S-${commit:0:12}-$random_hex"
}

create_worktree() {
  local name="$1"
  local commit="$2"
  local release_id="$3"
  local repo_dir
  local worktree

  repo_dir="$(repo_dir_for "$name")"
  worktree="$TMP_DIR/$name/$release_id/source"
  # The :? guards prevent rm -rf from running with an accidentally empty state
  # directory, deployment name, or release id.
  rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
  mkdir -p "$(dirname "$worktree")"

  git -C "$repo_dir" worktree prune
  git -C "$repo_dir" worktree add --detach "$worktree" "$commit" >&2
  if ! prepare_git_features "$worktree"; then
    cleanup_worktree_path "$repo_dir" "$worktree"
    # Repeat the same :? protected path removal after failed feature prep.
    rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
    remove_empty_directory_if_possible "$TMP_DIR/$name"
    return 1
  fi
  printf '%s\n' "$worktree"
}

cleanup_worktree() {
  local name="$1"
  local worktree="$2"
  local release_id="$3"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  cleanup_worktree_path "$repo_dir" "$worktree"
  # Keep the destructive cleanup tied to required path components.
  rm -rf "${TMP_DIR:?}/${name:?}/${release_id:?}"
  remove_empty_directory_if_possible "$TMP_DIR/$name"
}

cleanup_worktree_path() {
  local repo_dir="$1"
  local worktree="$2"

  if ! git -C "$repo_dir" worktree remove --force "$worktree" 2>/dev/null; then
    rm -rf "$worktree"
  fi
  git -C "$repo_dir" worktree prune
}

remove_empty_directory_if_possible() {
  local directory="$1"

  if rmdir "$directory" 2>/dev/null; then
    return 0
  fi
  return 0
}

copy_worktree_to_incoming() {
  local worktree="$1"
  local release_id="$2"
  local base
  local incoming
  local deploy_source="$worktree"
  local exclude_file="$TMP_DIR/excludes.$$.txt"
  local current_release=""
  local link_dest=""
  local rsync_args=()

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  incoming="$(incoming_release_dir_for "$base" "$release_id")"

  # Stage the exact filesystem that will become the next release. deploy_root
  # makes a repository subdirectory behave as the docroot root, while link_dest
  # deduplicates unchanged files against the active release.
  if [[ -n "${deploy_root:-}" ]]; then
    deploy_source="$worktree/$deploy_root"
  fi
  if [[ ! -d "$deploy_source" ]]; then
    echo "wpcloud-site-git-deploy: deploy root does not exist or is not a directory: ${deploy_root:-.}" >&2
    return 1
  fi

  rm -rf "$incoming"
  mkdir -p "$incoming"
  default_exclude_file "$exclude_file"

  if current_release="$(current_release_id)"; then
    if [[ -d "$(release_dir_for "$base" "$current_release")" ]]; then
      link_dest="$(release_dir_for "$base" "$current_release")"
    fi
  fi

  rsync_args=(-a --delete --exclude-from="$exclude_file")
  if [[ -n "$link_dest" ]]; then
    rsync_args+=(--checksum --no-times --link-dest="$link_dest")
  fi
  rsync "${rsync_args[@]}" "$deploy_source/" "$incoming/"
  rm -f "$exclude_file"
}

write_release_metadata() {
  local release_id="$1"
  local mode="$2"
  local ref_value="$3"
  local commit="$4"
  local metadata_dir

  metadata_dir="$(release_metadata_dir "$release_id")"
  mkdir -p "$metadata_dir"
  write_metadata_value "$metadata_dir" release_id "$release_id"
  write_metadata_value "$metadata_dir" ref_mode "$mode"
  write_metadata_value "$metadata_dir" ref_value "$ref_value"
  write_metadata_value "$metadata_dir" commit "$commit"
  write_metadata_value "$metadata_dir" deploy_root "${deploy_root:-}"
  write_metadata_value "$metadata_dir" deployed_at "$(date -u '+%Y-%m-%dT%H:%M:%SZ')"
}

release_metadata_dir() {
  local release_id="$1"
  local base

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  release_metadata_dir_for "$base" "$release_id"
}

write_metadata_value() {
  local metadata_dir="$1"
  local key="$2"
  local value="$3"
  local path="$metadata_dir/cfg-$key"
  local tmp_path="$path.tmp.$$"

  if [[ "$value" == *$'\n'* ]]; then
    die "release metadata value must not contain newlines: $key"
  fi
  printf '%s\n' "$value" >"$tmp_path"
  mv -f "$tmp_path" "$path"
}

metadata_value() {
  local metadata_dir="$1"
  local key="$2"
  local path="$metadata_dir/cfg-$key"

  if [[ ! -f "$path" ]]; then
    return 0
  fi
  cat "$path"
}

current_release_metadata_dir() {
  local current
  local metadata_dir

  if ! current="$(current_release_id)"; then
    current=""
  fi
  if [[ -z "$current" ]]; then
    return 1
  fi
  metadata_dir="$(release_metadata_dir "$current")"
  if [[ ! -d "$metadata_dir" ]]; then
    return 1
  fi
  printf '%s\n' "$metadata_dir"
}

current_release_matches() {
  local commit="$1"
  local expected_deploy_root="${2:-}"
  local metadata_dir
  local metadata_commit
  local metadata_deploy_root

  if ! metadata_dir="$(current_release_metadata_dir)"; then
    return 1
  fi
  metadata_commit="$(metadata_value "$metadata_dir" commit)"
  metadata_deploy_root="$(metadata_value "$metadata_dir" deploy_root)"

  if [[ "$metadata_commit" != "$commit" ]]; then
    return 1
  fi
  if [[ "$metadata_deploy_root" != "$expected_deploy_root" ]]; then
    return 1
  fi
  return 0
}

run_engine_subshell() {
  (
    cmd_remote_deploy "$@"
  )
}

promote_release() {
  local release_id="$1"
  local helper="$2"
  local post_deploy_file="${3:-}"
  local maintenance_file_value="${4:-$DEFAULT_MAINTENANCE_FILE}"
  local engine_args=()

  engine_args=(
    --docroot "$docroot" \
    --deployment-id "$deployment_id" \
    --release-id "$release_id" \
    --keep-releases "$keep_releases" \
    --maintenance-file "$maintenance_file_value"
  )
  if [[ -n "$helper" ]]; then
    engine_args+=(--exchange-helper "$helper")
  fi
  if [[ -n "$post_deploy_file" ]]; then
    engine_args+=(--post-deploy-file "$post_deploy_file")
  fi

  run_engine_subshell "${engine_args[@]}"
}

deploy_ref() {
  local name="$1"
  local mode="$2"
  local value="$3"
  local force="${4:-0}"
  local post_deploy_override="${5:-}"
  local maintenance_file_override="${6:-}"
  local commit
  local release_id
  local worktree
  local helper
  local effective_post_deploy
  local effective_maintenance_file

  # High-level deploy pipeline: refresh cache, resolve the requested ref,
  # create a unique release instance, stage it into incoming, promote through
  # the internal engine, then persist metadata for inspection and no-op checks.
  load_config "$name"
  ensure_state_dirs
  helper="$(ensure_helper)"
  effective_post_deploy="${post_deploy_override:-${post_deploy:-}}"
  effective_maintenance_file="${maintenance_file_override:-${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}}"
  fetch_repo "$name"
  commit="$(resolve_ref "$name" "$mode" "$value")"
  if [[ "$force" != "1" ]]; then
    if current_release_matches "$commit" "${deploy_root:-}"; then
      printf 'no-op %s %s %s\n' "$(current_release_id)" "$mode" "$commit"
      return 0
    fi
  fi
  release_id="$(make_release_id "$commit")"
  worktree="$(create_worktree "$name" "$commit" "$release_id")"
  if ! copy_worktree_to_incoming "$worktree" "$release_id"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  if ! promote_release "$release_id" "$helper" "$effective_post_deploy" "$effective_maintenance_file"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  if ! write_release_metadata "$release_id" "$mode" "$value" "$commit"; then
    cleanup_worktree "$name" "$worktree" "$release_id"
    return 1
  fi
  cleanup_worktree "$name" "$worktree" "$release_id"
  printf '%s %s %s\n' "$release_id" "$mode" "$commit"
}

current_release_id() {
  local base
  local current

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  current="$(current_path_for "$base")"
  if [[ ! -L "$current" ]]; then
    return 1
  fi
  readlink "$current" | sed 's#^releases/##'
}

select_rollback_release() {
  local base
  local current="${1:-}"
  local metadata_dir
  local release_name
  local metadata_candidates="$TMP_DIR/rollback-candidates.$$.txt"

  # Failed deployments can leave a release directory behind after incoming is
  # moved but before current is switched. Success metadata is written only after
  # promotion completes, so default rollback should prefer metadata-backed
  # releases instead of blindly picking the newest directory.
  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  printf '%s' '' >"$metadata_candidates"
  find "$(metadata_dir_for "$base")" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
    while IFS= read -r metadata_dir; do
      # Keep only the final path component from the metadata directory path;
      # metadata directories are named by release id.
      release_name="${metadata_dir##*/}"
      if [[ "$release_name" == "$current" ]]; then
        continue
      fi
      if [[ ! -d "$(release_dir_for "$base" "$release_name")" ]]; then
        continue
      fi
      release_dir_for "$base" "$release_name"
    done >"$metadata_candidates"

  if [[ -s "$metadata_candidates" ]]; then
    xargs ls -dt <"$metadata_candidates" 2>/dev/null |
      head -n 1 |
      xargs basename
    rm -f "$metadata_candidates"
    return 0
  fi
  rm -f "$metadata_candidates"

  find "$(releases_dir_for "$base")" -mindepth 1 -maxdepth 1 -type d 2>/dev/null |
    while IFS= read -r path; do
      # Compare only the final path component, which is the release id.
      if [[ "${path##*/}" == "$current" ]]; then
        continue
      fi
      printf '%s\n' "$path"
    done |
    xargs ls -dt 2>/dev/null |
    head -n 1 |
    xargs basename
}

# Auth And Doctor Helpers
#
# Repository URL parsing, deploy-key validation/import support, and diagnostic
# output helpers used by the auth and doctor public commands.

repo_host_from_url() {
  local url="$1"

  if [[ "$url" =~ ^[^@:/]+@([^:/]+):.+$ ]]; then
    # BASH_REMATCH[1] is the host captured from scp-style user@host:path URLs.
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$url" =~ ^ssh://[^@]+@([^/]+)/.+$ ]]; then
    # BASH_REMATCH[1] is the host captured from ssh://user@host/path URLs.
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ "$url" =~ ^https://([^/]+)/.+$ ]]; then
    # BASH_REMATCH[1] is the host captured from https://host/path URLs.
    printf '%s\n' "${BASH_REMATCH[1]}"
    return 0
  fi
  if [[ -d "$url" ]]; then
    printf 'local\n'
    return 0
  fi
  if [[ "$url" == /* ]]; then
    printf 'local\n'
    return 0
  fi
  if [[ "$url" == ./* ]]; then
    printf 'local\n'
    return 0
  fi
  if [[ "$url" == ../* ]]; then
    printf 'local\n'
    return 0
  fi
  return 1
}

https_to_ssh() {
  local url="$1"
  local host
  local path

  if [[ ! "$url" =~ ^https://([^/]+)/(.+)$ ]]; then
    return 1
  fi
  # BASH_REMATCH contains the host and repository path captured by the regex
  # above; this turns any https://host/path form into git@host:path.
  host="${BASH_REMATCH[1]}"
  path="${BASH_REMATCH[2]}"
  # Strip one leading slash defensively, even though the regex capture normally
  # starts after the slash between host and path.
  path="${path#/}"
  if [[ -z "$host" ]]; then
    return 1
  fi
  if [[ -z "$path" ]]; then
    return 1
  fi
  printf 'git@%s:%s\n' "$host" "$path"
}

private_key_public_key() {
  local path="$1"

  ssh-keygen -y -f "$path" </dev/null 2>/dev/null
}

key_mode_too_open() {
  local mode="$1"

  # 8# interprets the mode string as octal, then the mask checks whether any
  # group or other permission bits are set.
  (( (8#$mode) & 0077 ))
}

validate_existing_private_key() {
  local path="$1"
  local mode

  if ! command -v ssh-keygen >/dev/null 2>&1; then
    die "ssh-keygen is required to validate deploy keys"
  fi
  if [[ ! -f "$path" ]]; then
    die "private key is missing: $path"
  fi
  if [[ ! -r "$path" ]]; then
    die "private key is not readable: $path"
  fi
  mode="$(stat -c '%a' "$path")"
  if key_mode_too_open "$mode"; then
    die "private key permissions are too open: $mode"
  fi
  if ! private_key_public_key "$path" >/dev/null; then
    die "private key cannot be used without prompting or is not a valid private key: $path"
  fi
}

derive_public_key_file() {
  local private_key="$1"
  local public_key_path="$2"
  local tmp

  if ! command -v ssh-keygen >/dev/null 2>&1; then
    die "ssh-keygen is required to validate deploy keys"
  fi
  tmp="$(mktemp "${public_key_path}.tmp.XXXXXX")"
  if ! private_key_public_key "$private_key" >"$tmp"; then
    rm -f "$tmp"
    die "private key cannot be used without prompting or is not a valid private key: $private_key"
  fi
  mv "$tmp" "$public_key_path"
  chmod 644 "$public_key_path"
}

auth_resolve_key() {
  local name="$1"
  local force_new_key="$2"
  local use_key="$3"
  local import_key="$4"
  local key_path="$KEYS_DIR/${name}_ed25519"
  local public_key
  local import_key_real
  local key_path_real

  if [[ -n "$use_key" ]]; then
    validate_existing_private_key "$use_key"
    key_path="$use_key"
    public_key="$(private_key_public_key "$key_path")"
    printf 'Using existing deploy key: %s\n' "$key_path"
  elif [[ -n "$import_key" ]]; then
    validate_existing_private_key "$import_key"
    if [[ -e "$import_key" ]]; then
      if [[ -e "$key_path" ]]; then
        import_key_real="$(readlink -f "$import_key")"
        key_path_real="$(readlink -f "$key_path")"
      else
        import_key_real=""
        key_path_real=""
      fi
    else
      import_key_real=""
      key_path_real=""
    fi
    if [[ -n "$import_key_real" ]]; then
      if [[ "$import_key_real" == "$key_path_real" ]]; then
        die "cannot import the managed deploy key onto itself: $key_path"
      fi
    fi
    if [[ -e "$key_path" ]]; then
      if [[ "$force_new_key" -ne 1 ]]; then
        die "managed deploy key already exists: $key_path; use --force-new-key to replace it or --use-key PATH to reference an existing key without copying"
      fi
    fi
    rm -f "$key_path" "$key_path.pub"
    mkdir -p "$KEYS_DIR"
    chmod 700 "$KEYS_DIR"
    cp "$import_key" "$key_path"
    chmod 600 "$key_path"
    derive_public_key_file "$key_path" "$key_path.pub"
    public_key="$(cat "$key_path.pub")"
    printf 'Imported deploy key: %s\n' "$key_path"
  else
    if ((force_new_key)); then
      rm -f "$key_path" "$key_path.pub"
    fi
    if [[ -f "$key_path" ]]; then
      printf 'Reusing existing deploy key: %s\n' "$key_path"
    else
      if ! command -v ssh-keygen >/dev/null 2>&1; then
        die "ssh-keygen is required to create a deploy key"
      fi
      mkdir -p "$KEYS_DIR"
      chmod 700 "$KEYS_DIR"
      # umask 077 ensures ssh-keygen creates the private key owner-only even
      # before the explicit chmod below.
      (
        umask 077
        ssh-keygen -t ed25519 -N '' -C "wpcloud-site-git-deploy:$name" -f "$key_path" >/dev/null
      )
      chmod 600 "$key_path"
      chmod 644 "$key_path.pub"
      printf 'Created deploy key: %s\n' "$key_path"
    fi
    validate_existing_private_key "$key_path"
    if [[ -f "$key_path.pub" ]]; then
      public_key="$(cat "$key_path.pub")"
    else
      derive_public_key_file "$key_path" "$key_path.pub"
      public_key="$(cat "$key_path.pub")"
    fi
  fi

  AUTH_RESOLVED_KEY_PATH="$key_path"
  AUTH_RESOLVED_PUBLIC_KEY="$public_key"
}

doctor_check_commands() {
  local command_name
  local failures=0

  for command_name in bash git rsync find flock sort comm cut grep cat readlink ln rm mv mkdir mktemp touch stat date; do
    if command -v "$command_name" >/dev/null 2>&1; then
      printf 'OK command: %s found\n' "$command_name"
    else
      printf 'FAIL command: %s is required\n' "$command_name"
      failures=$((failures + 1))
    fi
  done
  if command -v ssh-keygen >/dev/null 2>&1; then
    printf 'OK command: ssh-keygen found\n'
  else
    printf 'WARN command: ssh-keygen not found; auth and configured key validation will be unavailable\n'
  fi

  ((failures == 0))
}

doctor_check_docroot() {
  if [[ -d "$docroot" ]]; then
    printf 'OK docroot: exists: %s\n' "$docroot"
    if [[ -w "$docroot" ]]; then
      printf 'OK docroot: writable: %s\n' "$docroot"
      return 0
    fi
    printf 'FAIL docroot: not writable: %s\n' "$docroot"
    return 1
  fi

  printf 'FAIL docroot: does not exist: %s\n' "$docroot"
  return 1
}

doctor_check_repo_url() {
  local host

  if repo_host_from_url "$repo_url" >/dev/null 2>&1; then
    host="$(repo_host_from_url "$repo_url")"
    printf 'OK repo: recognized host: %s\n' "$host"
    return 0
  fi

  printf 'FAIL repo: could not parse repository URL: %s\n' "$repo_url"
  return 1
}

doctor_check_exchange() {
  local helper

  if mv_exchange_available; then
    printf 'OK exchange: mv --exchange available\n'
    return 0
  fi
  if helper="$(ensure_helper 2>/dev/null)"; then
    if [[ -x "$helper" ]]; then
      printf 'OK helper: exchange-rename available: %s\n' "$helper"
      return 0
    fi
  fi

  printf 'FAIL exchange: mv --exchange and exchange-rename helper are unavailable\n'
  return 1
}

doctor_check_ssh_key() {
  local mode

  if [[ -z "${ssh_key_path:-}" ]]; then
    printf 'WARN ssh-key: no deploy key configured; Git will use default credentials or public repository access\n'
    return 0
  fi
  if [[ ! -f "$ssh_key_path" ]]; then
    printf 'FAIL ssh-key: private key is missing: %s\n' "$ssh_key_path"
    return 1
  fi
  if [[ ! -r "$ssh_key_path" ]]; then
    printf 'FAIL ssh-key: private key is not readable: %s\n' "$ssh_key_path"
    return 1
  fi

  mode="$(stat -c '%a' "$ssh_key_path")"
  if key_mode_too_open "$mode"; then
    printf 'FAIL ssh-key: private key permissions are too open: %s\n' "$mode"
    return 1
  fi

  printf 'OK ssh-key: private key is readable\n'
  if ! command -v ssh-keygen >/dev/null 2>&1; then
    printf 'FAIL ssh-key: ssh-keygen is required to validate deploy keys\n'
    return 1
  fi
  if private_key_public_key "$ssh_key_path" >/dev/null; then
    if [[ -f "$ssh_key_path.pub" ]]; then
      printf 'OK ssh-key: public key exists\n'
    else
      printf 'OK ssh-key: public key can be derived\n'
    fi
    return 0
  fi

  printf 'FAIL ssh-key: private key cannot be used without prompting or is not a valid private key: %s\n' "$ssh_key_path"
  return 1
}

doctor_check_git_lfs() {
  local name="$1"
  local repo_dir

  repo_dir="$(repo_dir_for "$name")"
  if [[ -d "$repo_dir/.git" ]]; then
    if git -C "$repo_dir" grep -q 'filter=lfs' HEAD -- .gitattributes >/dev/null 2>&1; then
      if command -v git-lfs >/dev/null 2>&1; then
        printf 'OK git-lfs: available for cached LFS-tracked repository\n'
        return 0
      fi
      printf 'FAIL git-lfs: git-lfs is required for cached LFS-tracked repository\n'
      return 1
    fi
  fi

  printf 'WARN git-lfs: not checked; no root .gitattributes LFS marker found in cached HEAD\n'
  return 0
}

doctor_check_git_remote() {
  local offline="$1"

  if ((offline)); then
    printf 'WARN git-remote: skipped remote access check because --offline was provided\n'
    return 0
  fi
  if git_with_auth ls-remote "$repo_url" HEAD >/dev/null 2>&1; then
    printf 'OK git-remote: remote access succeeded\n'
    return 0
  fi
  if [[ -z "${ssh_key_path:-}" ]]; then
    printf 'FAIL git-remote: remote access failed without a configured deploy key; run auth for private SSH repositories or check repository access\n'
  else
    printf 'FAIL git-remote: remote access failed; add the deploy key to the repository host or check repository access\n'
  fi
  return 1
}

# Public Command Handlers
#
# User-facing command implementations. These functions parse command-specific
# arguments with the argument helpers, load config as needed, and call the
# lower-level runtime/deploy helpers.

cmd_auth() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local force_new_key=0
  local verify=0
  local remove=0
  local purge_key=0
  local key_path
  local use_key=""
  local import_key=""
  local host
  local public_key

  # Configure exactly one deploy key source for this deployment: generated
  # managed key, external key path, imported managed copy, or removal.
  require_name "$name"
  args_begin_with_die die auth "$@"
  if arg_has --force-new-key; then
    force_new_key=1
  fi
  if arg_has --verify; then
    verify=1
  fi
  if arg_has --remove; then
    remove=1
  fi
  if arg_has --purge-key; then
    purge_key=1
  fi
  arg_set use_key --use-key
  arg_set import_key --import-key
  args_finish

  load_config "$name"
  ensure_state_dirs

  if ((remove)); then
    if ((verify)); then
      die "--remove cannot be combined with --verify, --force-new-key, --use-key, or --import-key"
    fi
    if ((force_new_key)); then
      die "--remove cannot be combined with --verify, --force-new-key, --use-key, or --import-key"
    fi
    if [[ -n "$use_key" ]]; then
      die "--remove cannot be combined with --verify, --force-new-key, --use-key, or --import-key"
    fi
    if [[ -n "$import_key" ]]; then
      die "--remove cannot be combined with --verify, --force-new-key, --use-key, or --import-key"
    fi
    key_path="${ssh_key_path:-}"
    ssh_key_path=""
    write_config "$name"
    printf 'Removed deploy key configuration for %s\n' "$name"
    if ((purge_key)); then
      if [[ -n "$key_path" ]]; then
        if [[ "$key_path" == "$KEYS_DIR"/* ]]; then
          rm -f "$key_path" "$key_path.pub"
          printf 'Deleted deploy key files for %s\n' "$name"
        else
          printf 'Did not delete external key files: %s\n' "$key_path"
        fi
      else
        printf 'No deploy key files configured for %s\n' "$name"
      fi
    fi
    return 0
  fi

  if ((purge_key)); then
    die "--purge-key requires --remove"
  fi
  if [[ -n "$use_key" ]]; then
    if [[ -n "$import_key" ]]; then
      die "choose only one deploy key source"
    fi
  fi
  if [[ -n "$use_key" ]]; then
    if [[ "$force_new_key" -eq 1 ]]; then
      die "--force-new-key can only be used with generated or imported keys"
    fi
  fi

  if [[ "$repo_url" =~ ^https:// ]]; then
    if ! repo_url="$(https_to_ssh "$repo_url")"; then
      die "could not convert HTTPS URL to SSH"
    fi
  fi
  if [[ ! "$repo_url" =~ ^[^@:/]+@[^:/]+:.+$ ]]; then
    if [[ ! "$repo_url" =~ ^ssh://[^@]+@[^/]+/.+$ ]]; then
      die "repository URL is not a Git SSH or HTTPS URL: $repo_url"
    fi
  fi

  auth_resolve_key "$name" "$force_new_key" "$use_key" "$import_key"
  key_path="$AUTH_RESOLVED_KEY_PATH"
  public_key="$AUTH_RESOLVED_PUBLIC_KEY"

  ssh_key_path="$key_path"
  write_config "$name"
  # repo_host_from_url is best-effort here: if parsing fails, the generic
  # instruction still prints with an empty host instead of aborting auth after
  # the key has already been configured.
  if ! host="$(repo_host_from_url "$repo_url")"; then
    host=""
  fi

  if [[ "$host" == "github.com" ]]; then
    printf 'Add this public key as a read-only GitHub deploy key for %s:\n' "$repo_url"
  else
    printf 'Add this public key to the repository host for %s with read-only access to %s:\n' "$host" "$repo_url"
  fi
  printf '%s\n' "$public_key"
  printf 'After adding the key, run: wpcloud-site-git-deploy doctor %s\n' "$name"

  if ((verify)); then
    if ! git_with_auth ls-remote "$repo_url" HEAD >/dev/null; then
      die "remote access failed; add the public key to the repository and try again"
    fi
    printf 'Verified remote access for %s\n' "$repo_url"
  fi
}

cmd_doctor() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local offline=0
  local doctor_failures=0

  # Report every setup problem found instead of failing on the first one so a
  # first-time user gets a complete repair checklist.
  require_name "$name"
  args_begin_with_die die doctor "$@"
  if arg_has --offline; then
    offline=1
  fi
  args_finish

  if load_config "$name"; then
    printf 'OK config: deployment loaded\n'
  else
    printf 'FAIL config: deployment is not initialized\n'
    return 1
  fi

  if ! doctor_check_commands; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_docroot; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_repo_url; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_exchange; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_ssh_key; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_git_lfs "$name"; then
    doctor_failures=$((doctor_failures + 1))
  fi
  if ! doctor_check_git_remote "$offline"; then
    doctor_failures=$((doctor_failures + 1))
  fi

  ((doctor_failures == 0))
}

cmd_config() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local action=""
  local action_value=""

  require_name "$name"
  args_begin_with_die die config "$@"
  arg_one_action action action_value \
    --deploy-root set-deploy-root require_deploy_root \
    --clear-deploy-root clear-deploy-root - \
    --post-deploy set-post-deploy require_post_deploy_path \
    --clear-post-deploy clear-post-deploy - \
    --maintenance-file set-maintenance-file require_maintenance_file
  args_finish

  load_config "$name"
  case "$action" in
    set-deploy-root)
      deploy_root="$action_value"
      write_config "$name"
      printf 'configured %s deploy_root=%s\n' "$name" "$deploy_root"
      ;;
    clear-deploy-root)
      deploy_root=""
      write_config "$name"
      printf 'cleared %s deploy_root\n' "$name"
      ;;
    set-post-deploy)
      post_deploy="$action_value"
      write_config "$name"
      printf 'configured %s post_deploy=%s\n' "$name" "$post_deploy"
      ;;
    clear-post-deploy)
      post_deploy=""
      write_config "$name"
      printf 'cleared %s post_deploy\n' "$name"
      ;;
    set-maintenance-file)
      maintenance_file="$action_value"
      write_config "$name"
      printf 'configured %s maintenance_file=%s\n' "$name" "$maintenance_file"
      ;;
  esac
}

cmd_init() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local repo=""
  local init_docroot=""
  local init_deployment_id=""
  local init_default_ref=""
  local init_keep_releases="$DEFAULT_KEEP_RELEASES"
  local init_deploy_root=""
  local init_maintenance_file="$DEFAULT_MAINTENANCE_FILE"

  require_name "$name"
  args_begin_with_die die init "$@"
  arg_set repo --repo
  arg_set init_docroot --docroot
  arg_set init_deployment_id --deployment-id
  arg_set init_default_ref --default-ref
  arg_set init_keep_releases --keep-releases
  arg_set init_deploy_root --deploy-root
  arg_set init_maintenance_file --maintenance-file
  args_finish

  if [[ -z "$repo" ]]; then
    die "--repo is required"
  fi
  if [[ -z "$init_docroot" ]]; then
    die "--docroot is required"
  fi
  if [[ -z "$init_deployment_id" ]]; then
    die "--deployment-id is required"
  fi
  if [[ -z "$init_default_ref" ]]; then
    die "--default-ref is required"
  fi
  if [[ ! "$init_deployment_id" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    die "deployment-id must be a normalized id"
  fi
  if ! is_positive_int "$init_keep_releases"; then
    die "--keep-releases must be a positive integer"
  fi
  if [[ -n "$init_deploy_root" ]]; then
    require_deploy_root "$init_deploy_root"
  fi
  require_maintenance_file "$init_maintenance_file"

  ensure_state_dirs
  ensure_helper >/dev/null
  repo_url="$repo"
  docroot="$init_docroot"
  deployment_id="$init_deployment_id"
  default_ref="$init_default_ref"
  keep_releases="$init_keep_releases"
  deploy_root="$init_deploy_root"
  maintenance_file="$init_maintenance_file"
  ssh_key_path=""
  write_config "$name"
  printf 'initialized %s\n' "$name"
}

cmd_deploy() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local mode=""
  local value=""
  local force=0
  local post_deploy_override=""
  local maintenance_file_override=""

  require_name "$name"
  args_begin_with_die die deploy "$@"
  if arg_has --force; then
    force=1
  fi
  arg_ref_choice mode value \
    --branch branch \
    --tag tag \
    --commit commit
  arg_set post_deploy_override --post-deploy require_post_deploy_path
  arg_set maintenance_file_override --maintenance-file require_maintenance_file
  args_finish

  if [[ -z "$mode" ]]; then
    die "deploy requires --branch, --tag, or --commit"
  fi
  if [[ -z "$value" ]]; then
    die "deploy requires --branch, --tag, or --commit"
  fi
  deploy_ref "$name" "$mode" "$value" "$force" "$post_deploy_override" "$maintenance_file_override"
}

cmd_update() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local force=0
  local post_deploy_override=""
  local maintenance_file_override=""

  require_name "$name"
  args_begin_with_die die update "$@"
  if arg_has --force; then
    force=1
  fi
  arg_set post_deploy_override --post-deploy require_post_deploy_path
  arg_set maintenance_file_override --maintenance-file require_maintenance_file
  args_finish

  load_config "$name"
  deploy_ref "$name" branch "$default_ref" "$force" "$post_deploy_override" "$maintenance_file_override"
}

cmd_rollback() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local to=""
  local helper
  local current
  local engine_args

  args_begin_with_die die rollback "$@"
  arg_set to --to
  args_finish

  load_config "$name"
  helper="$(ensure_helper)"
  if ! current="$(current_release_id)"; then
    current=""
  fi
  if [[ -z "$to" ]]; then
    to="$(select_rollback_release "$current")"
  fi
  if [[ -z "$to" ]]; then
    die "no rollback release available"
  fi
  engine_args=(--docroot "$docroot" --deployment-id "$deployment_id" --rollback-to "$to" --maintenance-file "$maintenance_file")
  if [[ -n "$helper" ]]; then
    engine_args+=(--exchange-helper "$helper")
  fi
  run_engine_subshell "${engine_args[@]}"
  printf 'rolled back to %s\n' "$to"
}

cmd_releases() {
  local name="${1:-}"
  local base
  local current
  local release
  local metadata
  local commit
  local ref_mode
  local ref_value
  local deploy_root

  load_config "$name"
  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  if ! current="$(current_release_id)"; then
    current=""
  fi
  find "$(releases_dir_for "$base")" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -r |
  while IFS= read -r release; do
    # Release directories are named by release id, so the final path component
    # is the display value and metadata lookup key.
    metadata="$(release_metadata_dir_for "$base" "${release##*/}")"
    printf '%s' "${release##*/}"
    if [[ "${release##*/}" == "$current" ]]; then
      printf ' current'
    fi
    if [[ -d "$metadata" ]]; then
      commit="$(metadata_value "$metadata" commit)"
      ref_mode="$(metadata_value "$metadata" ref_mode)"
      ref_value="$(metadata_value "$metadata" ref_value)"
      deploy_root="$(metadata_value "$metadata" deploy_root)"
      printf ' %s %s' "${commit:-unknown}" "${ref_mode:-unknown}:${ref_value:-unknown}"
      if [[ -n "${deploy_root:-}" ]]; then
        printf ' deploy-root:%s' "$deploy_root"
      fi
    fi
    printf '\n'
  done
}

cmd_branches() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local limit=20
  local fetch=0

  args_begin_with_die die branches "$@"
  if arg_has --fetch; then
    fetch=1
  fi
  arg_set limit --limit
  args_finish

  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" for-each-ref refs/remotes/origin --format='%(refname:short)' --sort=-committerdate |
    sed 's#^origin/##' |
    grep -v '^HEAD$' |
    head -n "$limit"
}

cmd_tags() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local limit=20
  local fetch=0

  args_begin_with_die die tags "$@"
  if arg_has --fetch; then
    fetch=1
  fi
  arg_set limit --limit
  args_finish

  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" for-each-ref refs/tags --format='%(refname:short)' --sort=-creatordate |
    head -n "$limit"
}

cmd_commits() {
  local name="${1:-}"
  if (($# > 0)); then
    shift
  fi
  local limit=20
  local fetch=0

  args_begin_with_die die commits "$@"
  if arg_has --fetch; then
    fetch=1
  fi
  arg_set limit --limit
  args_finish

  load_config "$name"
  if ((fetch)); then
    fetch_repo "$name"
  else
    ensure_repo_cache "$name"
  fi
  git -C "$(repo_dir_for "$name")" log --format='%H %s' -n "$limit" "origin/$default_ref"
}

cmd_status() {
  local name="${1:-}"
  load_config "$name"
  printf 'name=%s\n' "$name"
  printf 'repo=%s\n' "$repo_url"
  printf 'docroot=%s\n' "$docroot"
  printf 'deployment_id=%s\n' "$deployment_id"
  printf 'default_ref=%s\n' "$default_ref"
  printf 'keep_releases=%s\n' "$keep_releases"
  printf 'deploy_root=%s\n' "${deploy_root:-}"
  printf 'post_deploy=%s\n' "${post_deploy:-}"
  printf 'maintenance_file=%s\n' "${maintenance_file:-$DEFAULT_MAINTENANCE_FILE}"
  if current="$(current_release_id)"; then
    printf 'current=%s\n' "$current"
  else
    printf 'current=\n'
  fi
}

# Internal Promotion Engine
#
# Hidden __remote-deploy implementation that runs on the site host to reconcile
# claims, switch current releases, manage maintenance markers, run post-deploy
# hooks, rollback, prune releases, and audit public symlink invariants.

engine_usage() {
  cat <<-'USAGE'
	Usage: wpcloud-site-git-deploy __remote-deploy --docroot PATH --deployment-id ID --release-id ID --keep-releases N [--exchange-helper PATH] [--post-deploy-file PATH] [--maintenance-file PATH|none] [--print-claims]
	       wpcloud-site-git-deploy __remote-deploy --docroot PATH --deployment-id ID --rollback-to RELEASE_ID [--exchange-helper PATH] [--maintenance-file PATH|none]
	       wpcloud-site-git-deploy __remote-deploy --docroot PATH --assert-public-symlinks

	Promote an uploaded incoming release into the deployment namespace and update current.

	Options:
	  --post-deploy-file PATH
	                  Run this bash command file from the docroot after current is
	                  updated and stale symlinks are cleaned up. Failure exits
	                  nonzero without rolling back the active release.
	  --maintenance-file PATH|none
	                  Create a tool-owned WordPress maintenance marker during
	                  promotion or rollback. Use none to disable.
	  --print-claims  Print compressed claims for the incoming release and exit without
	                  promoting the release or changing current.
	  --rollback-to RELEASE_ID
	                  Re-point current to an existing release and reconcile managed
	                  public symlinks. Post-deploy commands are not run.
	  --exchange-helper PATH
	                  Helper binary that atomically swaps two paths with
	                  renameat2(RENAME_EXCHANGE). Defaults to the uploaded helper in
	                  the deployment namespace.
	  --assert-public-symlinks
	                  Validate that public symlink targets are relative and resolve
	                  under the docroot. This is an invariant check for the SSH CLI,
	                  where $HOME is not mounted during HTTP requests.
	USAGE
}

engine_die() {
  echo "wpcloud-site-git-deploy __remote-deploy: $*" >&2
  exit 64
}

trim() {
  local value="$1"
  # Remove leading whitespace by subtracting the longest all-whitespace prefix,
  # then remove trailing whitespace with the symmetric suffix expression.
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

engine_require_id() {
  local name="$1"
  local value="$2"

  if [[ ! "$value" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
    engine_die "$name must be a normalized id"
  fi
}

RUN_SCRATCH_DIR=""

cleanup_run_scratch() {
  if [[ -n "$RUN_SCRATCH_DIR" ]]; then
    if rm -rf -- "$RUN_SCRATCH_DIR" 2>/dev/null; then
      return 0
    fi
  fi
  return 0
}

maintenance_file_is_tool_owned() {
  local path="$1"
  local deployment_id="$2"

  if [[ -L "$path" ]]; then
    return 1
  fi
  if [[ ! -f "$path" ]]; then
    return 1
  fi
  if ! grep -Fxq "wpcloud-site-git-deploy maintenance" "$path"; then
    if ! grep -Fxq "// wpcloud-site-git-deploy maintenance" "$path"; then
      return 1
    fi
  fi
  if ! grep -Fxq "deployment_id=$deployment_id" "$path"; then
    if ! grep -Fxq "// deployment_id=$deployment_id" "$path"; then
      return 1
    fi
  fi
}

cleanup_owned_maintenance_file() {
  local docroot="$1"
  local deployment_id="$2"
  local maintenance_file="$3"
  local path

  if [[ -z "$maintenance_file" ]]; then
    return 0
  fi
  if [[ "$maintenance_file" == "none" ]]; then
    return 0
  fi
  path="$docroot/$maintenance_file"
  if maintenance_file_is_tool_owned "$path" "$deployment_id"; then
    rm -f -- "$path"
  fi
}

create_maintenance_file() {
  local docroot="$1"
  local deployment_id="$2"
  local release_id="$3"
  local maintenance_file="$4"
  local path
  local parent
  local tmp_path

  if [[ -z "$maintenance_file" ]]; then
    return 0
  fi
  if [[ "$maintenance_file" == "none" ]]; then
    return 0
  fi

  ENGINE_MAINTENANCE_OWNED=0
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  path="$docroot/$maintenance_file"
  if [[ -e "$path" ]]; then
    return 0
  fi
  if [[ -L "$path" ]]; then
    return 0
  fi

  # Drop the filename to inspect the parent directory for the maintenance file.
  parent="${path%/*}"
  if [[ ! -d "$parent" ]]; then
    # The message reports the configured parent path, not the full docroot path.
    engine_die "maintenance-file parent does not exist: ${maintenance_file%/*}"
  fi

  tmp_path="$path.$$"
  rm -f -- "$tmp_path"
  {
    printf '<?php\n'
    printf '%s\n' "\$upgrading = $(date +%s);"
    printf '// wpcloud-site-git-deploy maintenance\n'
    printf '// deployment_id=%s\n' "$deployment_id"
    printf '// release_id=%s\n' "$release_id"
    printf '// created_at=%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  } >"$tmp_path"
  mv -T "$tmp_path" "$path"
  ENGINE_MAINTENANCE_OWNED=1
}

ENGINE_MAINTENANCE_DOCROOT=""
ENGINE_MAINTENANCE_DEPLOYMENT_ID=""
ENGINE_MAINTENANCE_FILE="none"
ENGINE_MAINTENANCE_OWNED=0
ENGINE_MV_EXCHANGE=0

cleanup_engine_exit() {
  cleanup_run_scratch
  if [[ "$ENGINE_MAINTENANCE_OWNED" == "1" ]]; then
    if [[ -n "$ENGINE_MAINTENANCE_DOCROOT" ]]; then
      if [[ -n "$ENGINE_MAINTENANCE_DEPLOYMENT_ID" ]]; then
        cleanup_owned_maintenance_file \
          "$ENGINE_MAINTENANCE_DOCROOT" \
          "$ENGINE_MAINTENANCE_DEPLOYMENT_ID" \
          "$ENGINE_MAINTENANCE_FILE"
      fi
    fi
  fi
}

require_remote_capabilities() {
  local command_name
  local probe_dir

  for command_name in readlink flock find sort comm cut grep cat ln rm mv mkdir mktemp touch date; do
    if ! command -v "$command_name" >/dev/null 2>&1; then
      engine_die "$command_name is required"
    fi
  done

  # Later pruning depends on GNU find's timestamp output, and sticky/protected
  # discovery uses GNU-style predicates. Probing -printf is the cheap proxy for
  # GNU find as a whole.
  if ! probe_dir="$(mktemp -d "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-preflight.XXXXXX")"; then
    engine_die "mktemp is required"
  fi
  if ! find "$probe_dir" -mindepth 1 -maxdepth 1 -type d -printf '%T@\t%p\n' >/dev/null 2>&1; then
    rm -rf -- "$probe_dir"
    engine_die "GNU find with -printf is required"
  fi

  printf '%s' '' >"$probe_dir/source"
  if ! mv -T "$probe_dir/source" "$probe_dir/dest" 2>/dev/null; then
    rm -rf -- "$probe_dir"
    engine_die "atomic replacement requires mv -T"
  fi
  rm -rf -- "$probe_dir"
}

assert_public_symlinks_under_docroot() {
  local docroot="$1"
  local deployment_filter="${2:-}"
  local docroot_real
  local link_path
  local target
  local owner
  local parent_real
  local target_dir
  local target_base
  local resolved_dir
  local resolved
  local home_value="${HOME:-}"
  local links_tmp

  if ! docroot_real="$(cd "$docroot" && pwd -P)"; then
    engine_die "docroot does not exist: $docroot"
  fi

  # Public symlinks must be usable by HTTP. On WP Cloud, $HOME exists in SSH
  # sessions but is not mounted for web requests, so any target outside docroot
  # is a broken deployment even if it works over SSH.
  if ! links_tmp="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-links.XXXXXX")"; then
    engine_die "mktemp is required"
  fi
  if ! find "$docroot" -path "$docroot/$DOCROOT_NAMESPACE" -prune -o -type l -print0 >"$links_tmp" 2>/dev/null; then
    printf '%s' '' >"$links_tmp"
  fi
  # find/read use NUL delimiters so symlink paths containing spaces or shell
  # metacharacters are read exactly as filenames, not split like text.
  while IFS= read -r -d '' link_path; do
    target="$(readlink "$link_path")"

    if [[ -n "$deployment_filter" ]]; then
      if ! owner="$(deployment_owner_from_target "$target")"; then
        continue
      fi
      if [[ "$owner" != "$deployment_filter" ]]; then
        continue
      fi
    fi

    if [[ "$target" == /* ]]; then
      # Remove the docroot prefix from the diagnostic so failures report the
      # public claim path rather than the full filesystem path.
      engine_die "public symlink target is absolute: ${link_path#"$docroot"/}"
    fi
    if [[ -n "$home_value" ]]; then
      if [[ "$target" == *"$home_value"* ]]; then
        engine_die "public symlink target contains HOME: ${link_path#"$docroot"/}"
      fi
    fi

    if ! parent_real="$(cd "$(dirname "$link_path")" && pwd -P)"; then
      engine_die "could not resolve public symlink parent: ${link_path#"$docroot"/}"
    fi
    target_dir="$(dirname "$target")"
    target_base="$(basename "$target")"
    if ! resolved_dir="$(cd "$parent_real/$target_dir" 2>/dev/null && pwd -P)"; then
      engine_die "public symlink resolves outside docroot: ${link_path#"$docroot"/}"
    fi
    resolved="$resolved_dir/$target_base"

    case "$resolved" in
      "$docroot_real"/*)
        ;;
      *)
        engine_die "public symlink resolves outside docroot: ${link_path#"$docroot"/}"
        ;;
    esac
  done <"$links_tmp"
  rm -f -- "$links_tmp"
}

assert_claim_symlinks_under_docroot() {
  local docroot="$1"
  local claims_file="$2"
  local docroot_real
  local claim
  local public_path
  local target
  local resolved
  local home_value="${HOME:-}"

  if ! docroot_real="$(readlink -f "$docroot")"; then
    engine_die "docroot does not exist: $docroot"
  fi

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    if [[ -z "$claim" ]]; then
      continue
    fi
    public_path="$docroot/$claim"

    if [[ ! -L "$public_path" ]]; then
      engine_die "public claim is not a symlink: $claim"
    fi
    target="$(readlink "$public_path")"

    if [[ "$target" == /* ]]; then
      engine_die "public symlink target is absolute: $claim"
    fi
    if [[ -n "$home_value" ]]; then
      if [[ "$target" == *"$home_value"* ]]; then
        engine_die "public symlink target contains HOME: $claim"
      fi
    fi

    if ! resolved="$(readlink -f "$public_path")"; then
      engine_die "public symlink resolves outside docroot: $claim"
    fi
    case "$resolved" in
      "$docroot_real"/*)
        ;;
      *)
        engine_die "public symlink resolves outside docroot: $claim"
        ;;
    esac
  done <"$claims_file"
}

create_scratch_dir() {
  local base="$1"

  cleanup_run_scratch
  if ! RUN_SCRATCH_DIR="$(mktemp -d "$base/.tmp.XXXXXX")"; then
    engine_die "could not create scratch directory under $base"
  fi
  printf '%s\n' "$RUN_SCRATCH_DIR"
}

sweep_stale_scratch_dirs() {
  local base="$1"
  local scratch_path
  local scratch_list

  scratch_list="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-scratch.XXXXXX")"
  if find "$base" -mindepth 1 -maxdepth 1 -type d -name '.tmp.*' -print0 >"$scratch_list" 2>/dev/null; then
    while IFS= read -r -d '' scratch_path; do
      rm -rf -- "$scratch_path"
    done <"$scratch_list"
  fi
  rm -f -- "$scratch_list"
}

switch_current() {
  local base="$1"
  local release_id="$2"
  local current
  local tmp_current="$base/.current.$release_id.$$"

  current="$(current_path_for "$base")"
  rm -f "$tmp_current"
  ln -s "$(current_target_for "$release_id")" "$tmp_current"

  # Every public symlink points through current. Replacing current must therefore
  # be a single rename, never remove-then-create.
  if mv -T "$tmp_current" "$current" 2>/dev/null; then
    return 0
  fi

  rm -f "$tmp_current"
  engine_die "atomic current replacement requires mv -T"
}

acquire_lock() {
  local lock_file="$1"

  # fd 9 is just a private lock handle. There is no explicit unlock: the kernel
  # releases the flock when this process exits and closes the descriptor.
  exec 9>"$lock_file"
  if ! flock -n -x 9; then
    engine_die "deployment already running"
  fi
}

prune_releases() {
  local releases_dir="$1"
  local keep_releases="$2"
  local active_release="$3"
  local keep_non_active=$((keep_releases - 1))
  local retained=0
  local release_path
  local release_name
  local releases_list

  # Keep the active release plus the newest non-active releases. This preserves
  # rollback choices while avoiding deletion of the release currently serving.
  releases_list="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-releases.XXXXXX")"
  if find "$releases_dir" -mindepth 1 -maxdepth 1 -type d -printf '%T@\t%p\n' >"$releases_list" 2>/dev/null; then
    sort -rn "$releases_list" |
    while IFS=$'\t' read -r _ release_path; do
      # Release paths are sorted with a timestamp prefix; after reading the path,
      # keep only its final component to compare against the active release id.
      release_name="${release_path##*/}"
      if [[ "$release_name" == "$active_release" ]]; then
        continue
      fi

      if ((retained < keep_non_active)); then
        retained=$((retained + 1))
        continue
      fi

      rm -rf -- "$release_path"
    done
  fi
  rm -f -- "$releases_list"
}

run_post_deploy() {
  local docroot="$1"
  local post_deploy_file="$2"

  if [[ -z "$post_deploy_file" ]]; then
    return 0
  fi
  if [[ ! -f "$post_deploy_file" ]]; then
    engine_die "post-deploy file does not exist: $post_deploy_file"
  fi

  (
    cd "$docroot"
    bash -e "$post_deploy_file"
  )
}

public_symlink_target() {
  local deployment_id="$1"
  local claim="$2"
  local parent="$claim"
  local prefix=""

  # Build a relative target from the claim's parent directory. Example:
  # wp-content/plugins/foo -> ../../.wpcloud-site-git-deploy/.../current/wp-content/plugins/foo
  if [[ "$parent" == */* ]]; then
    # Remove the claim's final path component so each remaining parent
    # component contributes one ../ segment to the relative symlink target.
    parent="${parent%/*}"
    while [[ -n "$parent" ]]; do
      prefix="../$prefix"
      if [[ "$parent" == */* ]]; then
        # Peel off one parent component at a time from the right.
        parent="${parent%/*}"
      else
        parent=""
      fi
    done
  fi

  printf '%s%s/deployments/%s/current/%s\n' "$prefix" "$DOCROOT_NAMESPACE" "$deployment_id" "$claim"
}

reconcile_new_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local claims_file="$3"
  local exchange_helper="$4"
  local exchanged_paths_file="$5"
  local claim
  local public_path
  local parent_dir
  local target
  local tmp_link

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    if [[ -z "$claim" ]]; then
      continue
    fi

    public_path="$docroot/$claim"
    # Drop the filename portion to create the public parent directory, and use
    # the final filename component when building the temporary symlink name.
    parent_dir="${public_path%/*}"
    target="$(public_symlink_target "$deployment_id" "$claim")"
    tmp_link="$parent_dir/.${public_path##*/}.$DOCROOT_NAMESPACE_SUFFIX.$$"

    reject_foreign_deployment_ancestor_claim "$docroot" "$deployment_id" "$claim"
    mkdir -p -- "$parent_dir"
    reject_foreign_deployment_claim "$deployment_id" "$claim" "$public_path"
    reject_foreign_deployment_descendant_claim "$deployment_id" "$claim" "$public_path"
    rm -f -- "$tmp_link"
    ln -s "$target" "$tmp_link"

    if [[ ! -e "$public_path" ]]; then
      if [[ ! -L "$public_path" ]]; then
        mv -T -- "$tmp_link" "$public_path"
        continue
      fi
    fi

    # Existing public paths may contain real files/directories. Swap in the
    # deploy symlink atomically, then defer deletion of the exchanged-away path
    # until current points at the new release.
    if ((ENGINE_MV_EXCHANGE)); then
      if ! mv --exchange -- "$tmp_link" "$public_path"; then
        rm -f -- "$tmp_link"
        engine_die "mv --exchange failed to reclaim path: $claim"
      fi
    else
      if [[ ! -x "$exchange_helper" ]]; then
        engine_die "exchange helper is required to reclaim existing path: $claim"
      fi
      if ! "$exchange_helper" "$tmp_link" "$public_path"; then
        rm -f -- "$tmp_link"
        engine_die "exchange helper failed to reclaim path: $claim"
      fi
    fi
    printf '%s\n' "$tmp_link" >>"$exchanged_paths_file"
  done <"$claims_file"
}

cleanup_exchanged_paths() {
  local exchanged_paths_file="$1"
  local path

  # This file is durable on purpose. If cleanup failed after a prior atomic
  # exchange, the next deploy or rollback retries before changing claims again.
  if [[ ! -f "$exchanged_paths_file" ]]; then
    return 0
  fi
  while IFS= read -r path || [[ -n "$path" ]]; do
    if [[ -z "$path" ]]; then
      continue
    fi
    rm -rf -- "$path"
  done <"$exchanged_paths_file"
}

compute_removed_claims() {
  local old_claims_file="$1"
  local new_claims_file="$2"
  local removed_claims_file="$3"
  local old_sorted="$removed_claims_file.old.$$"
  local new_sorted="$removed_claims_file.new.$$"

  rm -f -- "$old_sorted" "$new_sorted"
  sort -u "$old_claims_file" >"$old_sorted"
  sort -u "$new_claims_file" >"$new_sorted"
  comm -23 "$old_sorted" "$new_sorted" >"$removed_claims_file"
  rm -f -- "$old_sorted" "$new_sorted"
}

deployment_owner_from_target() {
  local target="$1"

  if [[ "$target" =~ (^|/)$DOCROOT_NAMESPACE_REGEX/deployments/([^/]+)/current($|/) ]]; then
    # Capture group 2 is the deployment id embedded in deployment-owned public
    # symlink targets.
    printf '%s\n' "${BASH_REMATCH[2]}"
    return 0
  fi

  return 1
}

reject_foreign_deployment_claim() {
  local deployment_id="$1"
  local claim="$2"
  local public_path="$3"
  local target
  local owner

  if [[ ! -L "$public_path" ]]; then
    return 0
  fi

  target="$(readlink "$public_path")"
  if owner="$(deployment_owner_from_target "$target")"; then
    if [[ "$owner" != "$deployment_id" ]]; then
      engine_die "claim owned by another deployment: $claim"
    fi
  fi
}

reject_foreign_deployment_ancestor_claim() {
  local docroot="$1"
  local deployment_id="$2"
  local claim="$3"
  local ancestor="$docroot"
  local remainder="$claim"
  local component
  local target
  local owner

  # Layered deployments are allowed only when their public paths do not overlap.
  # A foreign ancestor symlink would route this claim into another deployment.
  while [[ "$remainder" == */* ]]; do
    # Walk from left to right through the claim: take the next component before
    # the slash, then leave the unvisited suffix in remainder.
    component="${remainder%%/*}"
    remainder="${remainder#*/}"
    ancestor="$ancestor/$component"

    if [[ -L "$ancestor" ]]; then
      target="$(readlink "$ancestor")"
      if owner="$(deployment_owner_from_target "$target")"; then
        if [[ "$owner" != "$deployment_id" ]]; then
          engine_die "claim owned by another deployment: $claim"
        fi
      fi
    fi
  done
}

reject_foreign_deployment_descendant_claim() {
  local deployment_id="$1"
  local claim="$2"
  local public_path="$3"
  local link_path
  local target
  local owner
  local links_tmp

  if [[ ! -d "$public_path" ]]; then
    return 0
  fi
  if [[ -L "$public_path" ]]; then
    return 0
  fi

  # Reclaiming a real directory is destructive to that exact path. Refuse when
  # it contains another deployment's symlink so layers cannot engulf each other.
  if ! links_tmp="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-descendants.XXXXXX")"; then
    engine_die "mktemp is required"
  fi
  if ! find "$public_path" -mindepth 1 -type l -print0 >"$links_tmp" 2>/dev/null; then
    printf '%s' '' >"$links_tmp"
  fi
  # NUL-delimited find output keeps arbitrary symlink paths intact.
  while IFS= read -r -d '' link_path; do
    target="$(readlink "$link_path")"
    if owner="$(deployment_owner_from_target "$target")"; then
      if [[ "$owner" != "$deployment_id" ]]; then
        engine_die "claim contains another deployment: $claim"
      fi
    fi
  done <"$links_tmp"
  rm -f -- "$links_tmp"
}

remove_exact_claim_symlink() {
  local docroot="$1"
  local deployment_id="$2"
  local claim="$3"
  local public_path="$docroot/$claim"
  local target
  local expected_target

  if [[ ! -L "$public_path" ]]; then
    return 0
  fi

  target="$(readlink "$public_path")"
  expected_target="$(public_symlink_target "$deployment_id" "$claim")"
  if [[ "$target" == "$expected_target" ]]; then
    rm -f -- "$public_path"
  fi
}

cleanup_removed_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local removed_claims_file="$3"
  local claim

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    if [[ -z "$claim" ]]; then
      continue
    fi
    remove_exact_claim_symlink "$docroot" "$deployment_id" "$claim"
  done <"$removed_claims_file"
}

cleanup_overlapping_removed_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local removed_claims_file="$3"
  local new_claims_file="$4"
  local removed_claim
  local new_claim

  while IFS= read -r removed_claim || [[ -n "$removed_claim" ]]; do
    if [[ -z "$removed_claim" ]]; then
      continue
    fi

    while IFS= read -r new_claim || [[ -n "$new_claim" ]]; do
      if [[ -z "$new_claim" ]]; then
        continue
      fi

      if [[ "$removed_claim" == "$new_claim" ]]; then
        remove_exact_claim_symlink "$docroot" "$deployment_id" "$removed_claim"
        break
      fi
      if [[ "$removed_claim" == "$new_claim/"* ]]; then
        remove_exact_claim_symlink "$docroot" "$deployment_id" "$removed_claim"
        break
      fi
      if [[ "$new_claim" == "$removed_claim/"* ]]; then
        remove_exact_claim_symlink "$docroot" "$deployment_id" "$removed_claim"
        break
      fi
    done <"$new_claims_file"
  done <"$removed_claims_file"
}

discover_materialized_public_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local output_file="$3"
  local claims_tmp="$output_file.tmp.$$"
  local links_tmp="$output_file.links.$$"
  local link_path
  local claim
  local target
  local expected_target

  rm -f -- "$claims_tmp" "$links_tmp"
  printf '%s' '' >"$claims_tmp"

  if ! find "$docroot" -path "$docroot/$DOCROOT_NAMESPACE" -prune -o -type l -print0 >"$links_tmp" 2>/dev/null; then
    printf '%s' '' >"$links_tmp"
  fi
  # shellcheck disable=SC2094
  # NUL-delimited reads preserve symlink paths exactly while this loop writes
  # only claims that still match this deployment's expected symlink target.
  while IFS= read -r -d '' link_path; do
    # Remove the absolute docroot prefix to turn the symlink path into a public
    # claim path relative to the web root.
    claim="${link_path#"$docroot"/}"

    if [[ "$claim" == *$'\n'* ]]; then
      rm -f -- "$claims_tmp" "$links_tmp"
      engine_die "unsupported newline in public symlink path"
    fi

    target="$(readlink "$link_path")"
    expected_target="$(public_symlink_target "$deployment_id" "$claim")"
    if [[ "$target" == "$expected_target" ]]; then
      printf '%s\n' "$claim"
    fi
  done <"$links_tmp" >"$claims_tmp"

  sort -u "$claims_tmp" >"$output_file"
  rm -f -- "$claims_tmp" "$links_tmp"
}

combine_claims() {
  local output_file="$1"
  shift
  local combined_tmp="$output_file.tmp.$$"

  rm -f -- "$combined_tmp"
  cat "$@" | sort -u >"$combined_tmp"
  mv "$combined_tmp" "$output_file"
}

normalize_public_path() {
  local value="$1"

  # Remove a leading ./ and then remove all trailing slashes so equivalent
  # public paths compare as the same claim.
  value="${value#./}"
  while [[ "$value" == */ ]]; do
    value="${value%/}"
  done

  if [[ "$value" == "." ]]; then
    value=""
  fi

  printf '%s' "$value"
}

discover_boundary_claims() {
  discover_docroot_paths \
    "$1" \
    "${WPCLOUD_SITE_GIT_DEPLOY_BOUNDARIES_FILE:-}" \
    "boundary" \
    "$2" \
    -type d \( -uid 0 -or -gid 0 \) -and -perm -1000
}

discover_protected_anchors() {
  local docroot="$1"
  local output_file="$2"
  discover_docroot_paths \
    "$docroot" \
    "${WPCLOUD_SITE_GIT_DEPLOY_PROTECTED_ANCHORS_FILE:-}" \
    "protected anchors" \
    "$output_file" \
    \( -uid 0 -or -gid 0 \) -and -not -writable
}

discover_docroot_paths() {
  local docroot="$1"
  local override_file="$2"
  local label="$3"
  local output_file="$4"
  shift 4
  local path
  local normalized
  local discovered_paths_file

  if [[ -n "$override_file" ]]; then
    if [[ ! -f "$override_file" ]]; then
      engine_die "$label override file does not exist: $override_file"
    fi
    while IFS= read -r path || [[ -n "$path" ]]; do
      normalized="$(normalize_public_path "$path")"
      printf '%s\n' "$normalized"
    done <"$override_file"
  else
    discovered_paths_file="$(mktemp "${TMPDIR:-/tmp}/wpcloud-site-git-deploy-docroot-paths.XXXXXX")"
    if ! find "$docroot" "$@" >"$discovered_paths_file" 2>/dev/null; then
      printf '%s' '' >"$discovered_paths_file"
    fi
    while IFS= read -r path; do
      if [[ "$path" == "$docroot" ]]; then
        normalized=""
      else
        # Convert an absolute docroot path discovered by find into the public
        # path relative to the docroot.
        normalized="$(normalize_public_path "${path#"$docroot"/}")"
      fi
      printf '%s\n' "$normalized"
    done <"$discovered_paths_file"
    rm -f -- "$discovered_paths_file"
  fi | sort -u >"$output_file"
}

validate_claims_not_protected() {
  local claims_file="$1"
  local protected_anchors_file="$2"
  local pair
  local tmp_prefix
  local ancestor_pairs_file
  local ancestor_keys_file
  local claim_keys_file
  local protected_ancestor_pairs_file
  local protected_ancestor_keys_file
  local protected_keys_file
  local blocked_anchors_file
  local blocked_claim

  tmp_prefix="${claims_file}.protected.$$"
  ancestor_pairs_file="$tmp_prefix.ancestor-pairs"
  ancestor_keys_file="$tmp_prefix.ancestor-keys"
  claim_keys_file="$tmp_prefix.claim-keys"
  protected_ancestor_pairs_file="$tmp_prefix.protected-ancestor-pairs"
  protected_ancestor_keys_file="$tmp_prefix.protected-ancestor-keys"
  protected_keys_file="$tmp_prefix.protected-keys"
  blocked_anchors_file="$tmp_prefix.blocked-anchors"

  # A claim is unsafe if it equals, descends from, or contains a protected
  # anchor. Expand both sides to ancestor sets so the overlap check stays in
  # standard sorted-file operations instead of nested path-walking logic.
  expand_ancestor_pairs "$claims_file" >"$ancestor_pairs_file"

  cut -f1 "$ancestor_pairs_file" | sort -u >"$ancestor_keys_file"
  sort -u "$claims_file" >"$claim_keys_file"
  sort -u "$protected_anchors_file" >"$protected_keys_file"
  comm -12 "$protected_keys_file" "$ancestor_keys_file" >"$blocked_anchors_file"

  expand_ancestor_pairs "$protected_keys_file" >"$protected_ancestor_pairs_file"

  cut -f1 "$protected_ancestor_pairs_file" | sort -u >"$protected_ancestor_keys_file"
  comm -12 "$claim_keys_file" "$protected_ancestor_keys_file" >>"$blocked_anchors_file"
  sort -u "$blocked_anchors_file" -o "$blocked_anchors_file"

  if [[ -s "$blocked_anchors_file" ]]; then
    blocked_claim="$(
      while IFS= read -r pair || [[ -n "$pair" ]]; do
        # ancestor_pairs_file stores "ancestor<TAB>claim". The prefix before
        # the tab is the key checked against blocked anchors; the suffix after
        # the first tab is the claim reported to the operator.
        if grep -Fxq -- "${pair%%$'\t'*}" "$blocked_anchors_file"; then
          printf '%s\n' "${pair#*$'\t'}"
          break
        fi
      done <"$ancestor_pairs_file"
    )"
    engine_die "protected path: $blocked_claim"
  fi
}

expand_ancestor_pairs() {
  local input_file="$1"
  local claim
  local ancestor

  while IFS= read -r claim || [[ -n "$claim" ]]; do
    ancestor="$claim"
    while true; do
      printf '%s\t%s\n' "$ancestor" "$claim"
      if [[ -z "$ancestor" ]]; then
        break
      fi

      if [[ "$ancestor" == */* ]]; then
        # Move one level upward by dropping the final path component.
        ancestor="${ancestor%/*}"
      else
        ancestor=""
      fi
    done
  done <"$input_file"
}

claim_for_path() {
  local public_path="$1"
  local boundaries_file="$2"
  local best_boundary=""
  local boundary
  local remainder
  local next_segment

  # Sticky boundaries mark dynamic areas such as wp-content/plugins. Inside the
  # deepest boundary, deploy only the next child as the public claim so one
  # plugin/theme does not claim the whole writable parent directory.
  while IFS= read -r boundary || [[ -n "$boundary" ]]; do
    if [[ -z "$boundary" ]]; then
      continue
    fi

    if [[ "$public_path" == "$boundary/"* ]]; then
      if ((${#boundary} > ${#best_boundary})); then
        best_boundary="$boundary"
      fi
    fi
  done <"$boundaries_file"

  if [[ -n "$best_boundary" ]]; then
    # Remove the sticky boundary prefix, then keep only the next path component
    # inside that boundary as the deploy claim.
    remainder="${public_path#"$best_boundary"/}"
    next_segment="${remainder%%/*}"
    printf '%s/%s\n' "$best_boundary" "$next_segment"
    return
  fi

  # Outside a sticky boundary, the top-level path component is the claim.
  printf '%s\n' "${public_path%%/*}"
}

rejected_shared_path_for_public_path() {
  local public_path="$1"
  local shared_path

  for shared_path in "${REJECTED_SHARED_PATHS[@]}"; do
    if [[ "$public_path" == "$shared_path" ]]; then
      printf '%s\n' "$shared_path"
      return 0
    fi
    if [[ "$public_path" == "$shared_path/"* ]]; then
      printf '%s\n' "$shared_path"
      return 0
    fi
  done
  return 1
}

shared_container_for_public_path() {
  local public_path="$1"
  local shared_path

  for shared_path in "${SHARED_CONTAINER_PATHS[@]}"; do
    if [[ "$public_path" == "$shared_path" ]]; then
      printf '%s\n' "$shared_path"
      return 0
    fi
    if [[ "$public_path" == "$shared_path/"* ]]; then
      printf '%s\n' "$shared_path"
      return 0
    fi
  done
  return 1
}

compute_claims() {
  local release_tree="$1"
  local boundaries_file="$2"
  local output_file="$3"
  local reject_shared_paths="${4:-0}"
  local release_file
  local public_path
  local shared_path
  local claims_tmp="$output_file.tmp.$$"
  local sorted_tmp="$output_file.sorted.$$"
  local find_tmp="$output_file.find.$$"

  rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
  if [[ ! -d "$release_tree" ]]; then
    printf '%s' '' >"$output_file"
    return 0
  fi

  find "$release_tree" \( -type f -or -type l \) -print0 >"$find_tmp"
  # shellcheck disable=SC2094
  # find emits NUL-delimited paths so spaces and shell metacharacters inside
  # repository filenames do not alter claim computation.
  while IFS= read -r -d '' release_file; do
    # Convert the absolute release-tree path into the public docroot-relative
    # path that will be claimed.
    public_path="${release_file#"$release_tree"/}"

    if [[ "$public_path" == *$'\n'* ]]; then
      rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
      engine_die "unsupported newline in release path"
    fi

    case "$public_path" in
      .git|.git/*)
        continue
        ;;
      "$DOCROOT_NAMESPACE"|"$DOCROOT_NAMESPACE"/*)
        # Never claim the deployment namespace itself. If caller-controlled
        # excludes allow the deployment namespace into a release, claiming it would
        # swap releases, lock, and helper for a symlink into that same release.
        continue
        ;;
    esac
    if [[ "$reject_shared_paths" == "1" ]]; then
      if shared_path="$(rejected_shared_path_for_public_path "$public_path")"; then
        rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
        engine_die "shared path cannot be deployed: $shared_path"
      fi
    fi
    if shared_path="$(shared_container_for_public_path "$public_path")"; then
      if [[ "$reject_shared_paths" == "1" ]]; then
        if [[ "$public_path" == "$shared_path" ]]; then
          rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
          engine_die "shared path cannot be deployed: $shared_path"
        fi
      fi
      if [[ "$reject_shared_paths" == "1" ]]; then
        if [[ -L "$release_file" ]]; then
          rm -f -- "$claims_tmp" "$sorted_tmp" "$find_tmp"
          engine_die "shared container symlink cannot be deployed: $public_path"
        fi
      fi
      printf '%s\n' "$public_path"
      continue
    fi

    claim_for_path "$public_path" "$boundaries_file"
  done <"$find_tmp" >"$claims_tmp"

  sort -u "$claims_tmp" >"$sorted_tmp"
  mv "$sorted_tmp" "$output_file"
  rm -f -- "$claims_tmp" "$find_tmp"
}

prepare_claim_transition() {
  local docroot="$1"
  local deployment_id="$2"
  local base="$3"
  local target_release_dir="$4"
  local scratch_dir="$5"
  local boundaries_file="$scratch_dir/boundaries"
  local protected_anchors_file="$scratch_dir/protected_anchors"
  local old_release_claims_file="$scratch_dir/old_release_claims"
  local materialized_claims_file="$scratch_dir/materialized_claims"
  local old_claims_file="$scratch_dir/old_claims"
  local new_claims_file="$scratch_dir/new_claims"
  local removed_claims_file="$scratch_dir/removed_claims"
  local current_target=""

  discover_boundary_claims "$docroot" "$boundaries_file"
  discover_protected_anchors "$docroot" "$protected_anchors_file"

  if [[ -L "$(current_path_for "$base")" ]]; then
    current_target="$(readlink "$(current_path_for "$base")")"
    compute_claims "$base/$current_target" "$boundaries_file" "$old_release_claims_file"
  else
    printf '%s' '' >"$old_release_claims_file"
  fi

  # The previous release tree is not the whole truth: public symlinks may have
  # survived manual repair or a failed cleanup. Include materialized symlinks so
  # removal/reclaim decisions reflect the actual docroot state.
  discover_materialized_public_claims "$docroot" "$deployment_id" "$materialized_claims_file"
  combine_claims "$old_claims_file" "$old_release_claims_file" "$materialized_claims_file"
  compute_claims "$target_release_dir" "$boundaries_file" "$new_claims_file" 1
  validate_claims_not_protected "$new_claims_file" "$protected_anchors_file"
  compute_removed_claims "$old_claims_file" "$new_claims_file" "$removed_claims_file"
}

apply_claim_transition() {
  local docroot="$1"
  local deployment_id="$2"
  local base="$3"
  local release_id="$4"
  local exchange_helper="$5"
  local scratch_dir="$6"
  local new_claims_file="$scratch_dir/new_claims"
  local removed_claims_file="$scratch_dir/removed_claims"
  local exchanged_paths_file

  exchanged_paths_file="$(exchanged_paths_file_for "$base")"

  printf '%s' '' >"$exchanged_paths_file"
  # Parent/child claim granularity can change between releases. Remove exact
  # overlapping old symlinks before creating new claims so they cannot block
  # parent/child directory creation.
  cleanup_overlapping_removed_claims "$docroot" "$deployment_id" "$removed_claims_file" "$new_claims_file"
  reconcile_new_claims "$docroot" "$deployment_id" "$new_claims_file" "$exchange_helper" "$exchanged_paths_file"
  switch_current "$base" "$release_id"
  if [[ "$(readlink "$(current_path_for "$base")")" != "$(current_target_for "$release_id")" ]]; then
    engine_die "current does not point to releases/$release_id"
  fi
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  # Non-overlapping removed claims are cleaned only after current points at the
  # new release, so public requests never see old symlinks pointing into a
  # not-yet-current tree.
  cleanup_removed_claims "$docroot" "$deployment_id" "$removed_claims_file"
  assert_claim_symlinks_under_docroot "$docroot" "$new_claims_file"
}

rollback_release() {
  local docroot="$1"
  local deployment_id="$2"
  local rollback_to="$3"
  local exchange_helper="$4"
  local maintenance_file="$5"

  local base
  local releases_dir
  local release_dir
  local lock_file
  local exchanged_paths_file
  local scratch_dir

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  releases_dir="$(releases_dir_for "$base")"
  release_dir="$(release_dir_for "$base" "$rollback_to")"
  lock_file="$(lock_path_for "$base")"
  exchanged_paths_file="$(exchanged_paths_file_for "$base")"

  mkdir -p "$releases_dir"

  acquire_lock "$lock_file"

  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  if [[ ! -d "$release_dir" ]]; then
    engine_die "rollback release does not exist: $release_dir"
  fi
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  sweep_stale_scratch_dirs "$base"

  scratch_dir="$(create_scratch_dir "$base")"
  create_maintenance_file "$docroot" "$deployment_id" "$rollback_to" "$maintenance_file"
  prepare_claim_transition "$docroot" "$deployment_id" "$base" "$release_dir" "$scratch_dir"
  apply_claim_transition "$docroot" "$deployment_id" "$base" "$rollback_to" "$exchange_helper" "$scratch_dir"
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  ENGINE_MAINTENANCE_OWNED=0

  echo "wpcloud-site-git-deploy __remote-deploy: current=$(current_target_for "$rollback_to")" >&2
}

validate_engine_arg_combination() {
  local release_id="$1"
  local rollback_to="$2"
  local keep_releases="$3"
  local post_deploy_file="$4"
  local print_claims="$5"

  if [[ -n "$rollback_to" ]]; then
    if [[ -n "$release_id" ]]; then
      engine_die "--release-id cannot be used with --rollback-to"
    fi
    if [[ -n "$keep_releases" ]]; then
      if ! is_positive_int "$keep_releases"; then
        engine_die "keep-releases must be a positive integer"
      fi
    fi
    if [[ -n "$post_deploy_file" ]]; then
      engine_die "--post-deploy-file cannot be used with --rollback-to"
    fi
    if ((print_claims != 0)); then
      engine_die "--print-claims cannot be used with --rollback-to"
    fi
    engine_require_id "rollback-to" "$rollback_to"
    return 0
  fi

  engine_require_id "release-id" "$release_id"
  if ! is_positive_int "$keep_releases"; then
    engine_die "keep-releases must be a positive integer"
  fi
}

print_release_claims() {
  local docroot="$1"
  local deployment_id="$2"
  local release_id="$3"
  local maintenance_file="$4"
  local base
  local incoming_dir
  local releases_dir
  local incoming_release
  local lock_file
  local exchanged_paths_file
  local scratch_dir
  local boundaries_file
  local new_claims_file

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  incoming_dir="$(incoming_dir_for "$base")"
  releases_dir="$(releases_dir_for "$base")"
  incoming_release="$(incoming_release_dir_for "$base" "$release_id")"
  lock_file="$(lock_path_for "$base")"
  exchanged_paths_file="$(exchanged_paths_file_for "$base")"

  mkdir -p "$incoming_dir" "$releases_dir"
  acquire_lock "$lock_file"

  if [[ ! -d "$incoming_release" ]]; then
    engine_die "incoming release does not exist: $incoming_release"
  fi
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  sweep_stale_scratch_dirs "$base"
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"

  scratch_dir="$(create_scratch_dir "$base")"
  boundaries_file="$scratch_dir/boundaries"
  new_claims_file="$scratch_dir/new_claims"
  discover_boundary_claims "$docroot" "$boundaries_file"
  compute_claims "$incoming_release" "$boundaries_file" "$new_claims_file" 1
  cat "$new_claims_file"
}

promote_incoming_release() {
  local docroot="$1"
  local deployment_id="$2"
  local release_id="$3"
  local keep_releases="$4"
  local exchange_helper="$5"
  local post_deploy_file="$6"
  local maintenance_file="$7"
  local base
  local incoming_dir
  local releases_dir
  local incoming_release
  local release_dir
  local lock_file
  local exchanged_paths_file
  local scratch_dir

  base="$(docroot_deployment_base "$docroot" "$deployment_id")"
  incoming_dir="$(incoming_dir_for "$base")"
  releases_dir="$(releases_dir_for "$base")"
  incoming_release="$(incoming_release_dir_for "$base" "$release_id")"
  release_dir="$(release_dir_for "$base" "$release_id")"
  lock_file="$(lock_path_for "$base")"
  exchanged_paths_file="$(exchanged_paths_file_for "$base")"

  mkdir -p "$incoming_dir" "$releases_dir"
  acquire_lock "$lock_file"

  if [[ ! -d "$incoming_release" ]]; then
    engine_die "incoming release does not exist: $incoming_release"
  fi
  cleanup_exchanged_paths "$exchanged_paths_file"
  rm -f -- "$exchanged_paths_file"
  sweep_stale_scratch_dirs "$base"
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"

  scratch_dir="$(create_scratch_dir "$base")"
  if [[ -e "$release_dir" ]]; then
    engine_die "release already exists: $release_dir"
  fi

  create_maintenance_file "$docroot" "$deployment_id" "$release_id" "$maintenance_file"
  prepare_claim_transition "$docroot" "$deployment_id" "$base" "$incoming_release" "$scratch_dir"
  mv "$incoming_release" "$release_dir"
  # Uploaded directory mtimes reflect upload time. Refresh the promoted release
  # mtime so keep-releases pruning keeps the most recently promoted releases.
  touch "$release_dir"
  apply_claim_transition "$docroot" "$deployment_id" "$base" "$release_id" "$exchange_helper" "$scratch_dir"
  if ! run_post_deploy "$docroot" "$post_deploy_file"; then
    cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
    ENGINE_MAINTENANCE_OWNED=0
    engine_die "post-deploy failed: $post_deploy_file"
  fi
  cleanup_owned_maintenance_file "$docroot" "$deployment_id" "$maintenance_file"
  ENGINE_MAINTENANCE_OWNED=0
  prune_releases "$releases_dir" "$keep_releases" "$release_id"

  echo "wpcloud-site-git-deploy __remote-deploy: current=$(current_target_for "$release_id")" >&2
}

cmd_remote_deploy() {
  local docroot=""
  local deployment_id=""
  local release_id=""
  local rollback_to=""
  local keep_releases=""
  local post_deploy_file=""
  local maintenance_file="$DEFAULT_MAINTENANCE_FILE"
  local exchange_helper=""
  local print_claims=0
  local assert_public_symlinks=0
  local show_help=0
  local show_help_short=0
  local show_version=0

  # Hidden internal/diagnostic command. The public deploy path calls this in a
  # subshell after rsyncing incoming content so engine exits cannot bypass the
  # outer cleanup paths.
  args_begin_with_die engine_die argument "$@"
  if arg_has --help; then
    show_help=1
  fi
  if arg_has -h; then
    show_help_short=1
  fi
  if arg_has --version; then
    show_version=1
  fi
  if arg_has --print-claims; then
    print_claims=1
  fi
  if arg_has --assert-public-symlinks; then
    assert_public_symlinks=1
  fi
  arg_set docroot --docroot
  arg_set deployment_id --deployment-id
  arg_set release_id --release-id
  arg_set rollback_to --rollback-to
  arg_set keep_releases --keep-releases
  arg_set post_deploy_file --post-deploy-file
  arg_set maintenance_file --maintenance-file
  arg_set exchange_helper --exchange-helper
  if ((show_help)); then
    engine_usage
    exit 0
  fi
  if ((show_help_short)); then
    engine_usage
    exit 0
  fi
  if ((show_version)); then
    echo "$VERSION"
    exit 0
  fi
  args_finish

  docroot="$(trim "$docroot")"
  deployment_id="$(trim "$deployment_id")"
  release_id="$(trim "$release_id")"
  rollback_to="$(trim "$rollback_to")"
  keep_releases="$(trim "$keep_releases")"
  post_deploy_file="$(trim "$post_deploy_file")"
  maintenance_file="$(trim "$maintenance_file")"
  exchange_helper="$(trim "$exchange_helper")"

  if [[ -z "$docroot" ]]; then
    engine_die "docroot is required"
  fi
  require_maintenance_file "$maintenance_file" engine_die

  if ((assert_public_symlinks)); then
    trap cleanup_run_scratch EXIT
    require_remote_capabilities
    assert_public_symlinks_under_docroot "$docroot"
    return
  fi

  engine_require_id "deployment-id" "$deployment_id"
  if mv_exchange_available; then
    ENGINE_MV_EXCHANGE=1
  else
    ENGINE_MV_EXCHANGE=0
    if [[ -z "$exchange_helper" ]]; then
      exchange_helper="$(docroot_deployment_base "$docroot" "$deployment_id")/exchange-rename"
    fi
  fi

  ENGINE_MAINTENANCE_DOCROOT="$docroot"
  ENGINE_MAINTENANCE_DEPLOYMENT_ID="$deployment_id"
  ENGINE_MAINTENANCE_FILE="$maintenance_file"
  ENGINE_MAINTENANCE_OWNED=0
  trap cleanup_engine_exit EXIT
  require_remote_capabilities

  validate_engine_arg_combination "$release_id" "$rollback_to" "$keep_releases" "$post_deploy_file" "$print_claims"
  if [[ -n "$rollback_to" ]]; then
    rollback_release "$docroot" "$deployment_id" "$rollback_to" "$exchange_helper" "$maintenance_file"
    return
  fi

  if ((print_claims)); then
    print_release_claims "$docroot" "$deployment_id" "$release_id" "$maintenance_file"
    return
  fi

  promote_incoming_release "$docroot" "$deployment_id" "$release_id" "$keep_releases" "$exchange_helper" "$post_deploy_file" "$maintenance_file"
}

# Final Command Dispatcher
#
# Top-level command router. Keep this last so all public and hidden command
# handlers are defined before dispatch.

main() {
  local command="${1:-}"
  if (($# > 0)); then
    shift
  fi

  case "$command" in
    init)
      cmd_init "$@"
      ;;
    config)
      cmd_config "$@"
      ;;
    deploy)
      cmd_deploy "$@"
      ;;
    update)
      cmd_update "$@"
      ;;
    rollback)
      cmd_rollback "$@"
      ;;
    releases)
      cmd_releases "$@"
      ;;
    branches)
      cmd_branches "$@"
      ;;
    tags)
      cmd_tags "$@"
      ;;
    commits)
      cmd_commits "$@"
      ;;
    status)
      cmd_status "$@"
      ;;
    auth)
      cmd_auth "$@"
      ;;
    doctor)
      cmd_doctor "$@"
      ;;
    __remote-deploy)
      cmd_remote_deploy "$@"
      ;;
    --help|-h|"")
      usage
      ;;
    --version)
      echo "$VERSION"
      ;;
    *)
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
